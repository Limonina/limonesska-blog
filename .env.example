# Supabase — для глобальных лайков (см. src/pages/api/like.ts).
# Скопируй в .env и впиши значения из Supabase → Project Settings → API.
# SERVICE_KEY секретный (service_role), на клиент не уходит — только в серверных ручках.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
