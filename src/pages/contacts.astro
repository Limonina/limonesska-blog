---
import BaseLayout from '../layouts/BaseLayout.astro';

// ⤵️ Лиона редактирует. Способы связи.
const email = 'limonesska@gmail.com';
const socials = [
  { label: 'Telegram', handle: '@limonesska_ru', href: 'https://t.me/limonesska_ru' },
  { label: 'Instagram', handle: '@limonesska', href: 'https://www.instagram.com/limonesska/', star: true },
  { label: 'ВКонтакте', handle: 'vk.com/limonesska', href: 'https://vk.com/limonesska' },
];
---

<BaseLayout title="Контакты | limonesska">
    <section class="contacts">
        <header class="contacts-head">
            <h1 class="contacts-title">Контакты</h1>
            <p class="contacts-lead">
                Пиши — отвечаю в соцсетях быстрее, чем на почту. Анонсы новых постов
                и заметок тоже там.
            </p>
        </header>

        <ul class="contact-list">
            <li class="contact">
                <span class="contact-label">Почта</span>
                <a class="contact-link" href={`mailto:${email}`}>{email}</a>
            </li>
            {socials.map((s) => (
                <li class="contact">
                    <span class="contact-label">{s.label}{s.star && <sup class="ext-star">*</sup>}</span>
                    <a class="contact-link" href={s.href} target="_blank" rel="noopener noreferrer">{s.handle}</a>
                </li>
            ))}
        </ul>

        <p class="contacts-ext-note">* Instagram принадлежит компании Meta, признанной в РФ экстремистской организацией и запрещённой.</p>
    </section>

    <style is:global>
        .contacts { max-width: 760px; margin: 0 auto; }
        .ext-star { color: var(--color-text-faint); font-size: 0.95rem; }
        .contacts-ext-note { margin-top: 28px; font-family: var(--font-ui); font-size: var(--size-small); line-height: 1.5; color: var(--color-text-faint); }

        .contacts-head { margin-bottom: 48px; }
        .contacts-title {
            font-family: var(--font-display);
            font-size: var(--size-mega);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -1px;
            color: var(--text);
            margin: 0 0 18px;
        }
        .contacts-lead {
            font-family: var(--font-vollkorn);
            font-size: var(--size-medium);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0;
            max-width: 34em;
        }

        .contact-list { list-style: none; margin: 0; padding: 0; }
        .contact {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 16px;
            padding: 18px 0;
            border-top: 1px solid var(--line);
        }
        .contact-label {
            font-family: var(--font-ui);
            font-size: var(--size-small);
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--accent-2);
        }
        .contact-link {
            font-family: var(--font-vollkorn);
            font-size: var(--size-h3);
            color: var(--text);
            text-decoration: none;
            transition: color 0.2s;
        }
        .contact-link:hover { color: var(--accent); }

        @media (max-width: 600px) {
            .contact { flex-direction: column; gap: 4px; }
            .contact-link { font-size: var(--size-medium); }
        }
    </style>
</BaseLayout>
