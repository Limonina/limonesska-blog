---
import BaseLayout from '../layouts/BaseLayout.astro';

// ⤵️ Лиона редактирует. Каждая запись — термин.
//   term — слово, def — определение «своими словами», aka — синонимы (опц.)
const terms = [
  {
    term: 'Антибиблиотека',
    def: 'Книги, которые ещё не прочитаны, но уже стоят на полке — собрание того, чего я пока не знаю. Ценнее прочитанного: напоминает, как многое впереди.',
    aka: ['antilibrary'],
  },
  {
    term: 'Вайб-коддинг',
    def: 'Когда пишешь код на интуиции и в потоке, вместе с ИИ, не дожидаясь идеального плана — главное движение и работающий результат.',
    aka: [],
  },
  {
    term: 'Дневник экспериментов',
    def: 'Мой формат блога: не вылизанный экспертный результат, а живой процесс — пробую, ошибаюсь, показываю как есть. Ценность в самом движении, а не в идеальной картинке.',
    aka: [],
  },
  {
    term: 'Моя броня',
    def: 'Этот сайт — живое, постоянно растущее пространство мыслей, заметок и связей, а не линейный блог. Растёт по чешуйке: то, что собирается со временем и делает меня устойчивее.',
    aka: ['цифровой сад', 'digital garden'],
  },
];

// Группировка по первой букве
const sorted = [...terms].sort((a, b) => a.term.localeCompare(b.term, 'ru'));
const groups = sorted.reduce((acc, t) => {
  const letter = t.term[0].toUpperCase();
  (acc[letter] ??= []).push(t);
  return acc;
}, {});
---

<BaseLayout title="Глоссарий | limonesska">
    <section class="glossary">
        <header class="gl-head">
            <h1 class="gl-title">Глоссарий</h1>
            <p class="gl-lead">
                Слова, которые я использую на сайте — своими словами. Личный словарь,
                чтобы не объяснять одно и то же дважды.
            </p>
        </header>

        {Object.entries(groups).map(([letter, items]) => (
            <div class="gl-group">
                <span class="gl-letter">{letter}</span>
                <dl class="gl-list">
                    {items.map((t) => (
                        <div class="gl-entry" id={encodeURIComponent(t.term.toLowerCase())}>
                            <dt class="gl-term">
                                {t.term}
                                {t.aka && t.aka.length > 0 && (
                                    <span class="gl-aka">{t.aka.join(' · ')}</span>
                                )}
                            </dt>
                            <dd class="gl-def">{t.def}</dd>
                        </div>
                    ))}
                </dl>
            </div>
        ))}
    </section>

    <style is:global>
        .glossary { max-width: 760px; margin: 0 auto; }

        .gl-head { margin-bottom: 48px; }
        .gl-title {
            font-family: var(--font-display);
            font-size: var(--size-mega);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -1px;
            color: var(--text);
            margin: 0 0 18px;
        }
        .gl-lead {
            font-family: var(--font-vollkorn);
            font-size: var(--size-medium);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0;
            max-width: 36em;
        }

        .gl-group {
            display: grid;
            grid-template-columns: 64px 1fr;
            gap: 8px;
            margin-bottom: 8px;
        }
        .gl-letter {
            font-family: var(--font-display);
            font-size: var(--size-h2);
            color: var(--accent-2);
            line-height: 1;
            position: sticky;
            top: 110px;
        }

        .gl-list { margin: 0; }
        .gl-entry {
            padding: 18px 0;
            border-top: 1px solid var(--line);
        }
        .gl-entry:first-child { border-top: none; padding-top: 0; }

        .gl-term {
            font-family: var(--font-vollkorn);
            font-size: var(--size-h3);
            font-weight: 600;
            color: var(--text);
            margin: 0 0 6px;
            display: flex;
            align-items: baseline;
            flex-wrap: wrap;
            gap: 10px;
        }
        .gl-aka {
            font-family: var(--font-ui);
            font-size: var(--size-small);
            font-weight: 400;
            color: var(--color-text-faint);
            font-style: italic;
        }
        .gl-def {
            font-family: var(--font-vollkorn);
            font-size: var(--size-base);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0;
            max-width: 40em;
        }

        @media (max-width: 600px) {
            .gl-group { grid-template-columns: 1fr; gap: 4px; }
            .gl-letter { position: static; font-size: var(--size-h3); margin-bottom: 8px; }
        }
    </style>
</BaseLayout>
