---
import BaseLayout from '../layouts/BaseLayout.astro';
import bg from '../assets/background.svg?raw';
---

<BaseLayout title="404 — эта чешуйка ещё куётся | limonesska">
    <section class="notfound">
        <div class="nf-bgimg" aria-hidden="true" set:html={bg}></div>
        <div class="nf-inner">
        <div class="nf-code" aria-hidden="true">404</div>

        <h1 class="nf-title">Эта чешуйка ещё куётся</h1>

        <p class="nf-text">
            Страница, которую ты ищешь, пока <strong>в разработке</strong> — дракон ещё
            не нарастил эту часть брони. Загляни позже или вернись в обжитую часть.
        </p>

        <div class="nf-actions">
            <a href="/" class="nf-btn nf-btn--primary">← На главную</a>
            <a href="/blog" class="nf-btn nf-btn--secondary">Читать блог</a>
        </div>

        <p class="nf-hint">Ошибка 404 · страница не найдена</p>
        </div>
    </section>

    <style is:global>
        .notfound {
            position: relative;
            max-width: 640px;
            margin: 0 auto;
            padding: clamp(48px, 10vh, 120px) 20px;
            text-align: center;
        }
        .nf-inner { position: relative; z-index: 1; }

        /* фоновая иллюстрация: во всю ширину, низом встык к подвалу */
        .nf-bgimg {
            position: absolute;
            left: 50%;
            bottom: -60px;            /* съедаем нижний padding main-content → встык к подвалу */
            transform: translateX(-50%);
            width: 100vw;
            pointer-events: none;
            user-select: none;
            z-index: 0;
        }
        .nf-bgimg svg {
            display: block;
            width: 100%;
            height: auto;
        }
        /* перекраска под тему: всё зелёным (--accent-2 разный в светлой/тёмной) */
        .nf-bgimg svg [fill="#7D5C3F"]   { fill: var(--accent-2); }
        .nf-bgimg svg [stroke="#7D5C3F"] { stroke: var(--accent-2); }
        .nf-bgimg svg [stroke="black"]   { stroke: var(--accent-2); }

        @media (max-width: 768px) {
            .nf-bgimg { bottom: -40px; }
        }

        .nf-code {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.1em;
            font-family: var(--font-display);
            font-size: clamp(5rem, 22vw, 11rem);
            line-height: 1;
            letter-spacing: 0.08em;
            color: var(--accent);
            margin-bottom: 24px;
            user-select: none;
        }

        .nf-title {
            font-family: var(--font-display);
            font-size: var(--size-h2);
            color: var(--text);
            margin: 0 0 16px;
        }

        .nf-text {
            font-family: var(--font-vollkorn);
            font-size: var(--size-medium);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0 auto 32px;
            max-width: 30em;
        }

        .nf-text strong { color: var(--text); }

        .nf-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 14px;
            margin-bottom: 40px;
        }

        .nf-btn {
            font-family: var(--font-ui);
            font-size: var(--size-medium);
            font-weight: 600;
            text-decoration: none;
            padding: 14px 28px;
            border-radius: 8px;
            transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
        }

        /* как «Читать блог» (.btn-primary) на главной — без съезда вверх */
        .nf-btn--primary {
            background: var(--text);
            color: var(--color-surface);
            border: 1px solid var(--text);
        }
        .nf-btn--primary:hover {
            background: var(--text-muted);
            border-color: var(--text-muted);
        }

        .nf-btn--secondary {
            background: transparent;
            color: var(--text);
            border: 1px solid var(--line);
        }
        .nf-btn--secondary:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .nf-hint {
            font-family: var(--font-ui);
            font-size: var(--size-small);
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--color-text-faint);
        }
    </style>
</BaseLayout>
