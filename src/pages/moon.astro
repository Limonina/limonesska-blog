---
import BaseLayout from '../layouts/BaseLayout.astro';
// Все данные (фазы, затмения, ретрограды, луна без курса) считаются в браузере
// библиотекой astronomy-engine — вписывать ничего не нужно.
// Времена показываются по Москве (UTC+3). VoC — классические аспекты Луны
// (0/60/90/120/180°) к Солнцу…Сатурну до смены знака.
---

<BaseLayout title="Лунный календарь | limonesska">
    <section class="moon">
        <header class="moon-head">
            <h1 class="moon-title">Лунный календарь</h1>
            <p class="moon-lead">
                Фазы Луны по дням, периоды «Луны без курса», затмения и ретрограды планет.
                Всё считается автоматически; время — московское.
            </p>
        </header>

        <div class="moon-bar">
            <button class="moon-nav" data-step="prev" aria-label="Предыдущий месяц">‹</button>
            <h2 class="moon-label" id="moon-label">…</h2>
            <button class="moon-nav" data-step="next" aria-label="Следующий месяц">›</button>
        </div>

        <div class="moon-stage">
            <aside class="moon-note" id="moon-note" hidden></aside>
            <div class="moon-calendar">
                <div class="moon-weekdays">
                    <div>Пн</div><div>Вт</div><div>Ср</div><div>Чт</div><div>Пт</div><div>Сб</div><div>Вс</div>
                </div>
                <div class="moon-grid" id="moon-grid"></div>
            </div>
            <aside class="moon-detail" id="moon-detail" hidden></aside>
        </div>

        <div class="moon-legend">
            <span><span class="lg-moon">🌙</span> Луна без курса</span>
            <span><span class="lg-dot lg-ecl"></span> затмение</span>
            <span><span class="lg-arrow">↗</span> растёт · <span class="lg-arrow">↘</span> убывает</span>
            <span>ретроград (полоса снизу):
                <span class="lg-bar" style="background:#e0a93f"></span>☿
                <span class="lg-bar" style="background:#ec5fa0"></span>♀
                <span class="lg-bar" style="background:#5b9bd5"></span>♂
            </span>
        </div>

        <div class="moon-toolbar">
            <button class="moon-print-btn" id="moon-print-btn">🖨 Распечатать год</button>
        </div>
    </section>

    <div class="moon-overlay" id="moon-overlay" hidden>Готовлю календарь к печати…</div>
    <div class="moon-print" id="moon-print" aria-hidden="true"></div>

    <style is:global>
        .moon { max-width: 1000px; margin: 0 auto; }
        /* сцена: заметка «нельзя планировать» слева · календарь · инфо о дне справа */
        .moon-stage {
            display: flex; align-items: flex-start; justify-content: center; gap: 20px;
            width: 100%;
        }
        .moon-calendar { flex: 0 0 auto; width: 1000px; max-width: 100%; margin: 0 auto; }
        .moon-note, .moon-detail { flex: 0 0 300px; align-self: stretch; }
        .moon-note[hidden], .moon-detail[hidden] { display: none; }
        /* когда открыта хоть одна панель — сцене нужна доп. ширина по бокам (сетка не сжимается) */
        .moon.has-panel { max-width: 1640px; }
        .moon.has-panel .moon-head,
        .moon.has-panel .moon-bar,
        .moon.has-panel .moon-legend,
        .moon.has-panel .moon-toolbar { max-width: 1000px; margin-left: auto; margin-right: auto; }
        .moon-head { margin-bottom: 28px; }
        .moon-title {
            font-family: var(--font-display); font-size: var(--size-mega);
            font-weight: 700; line-height: 1.1; letter-spacing: -1px;
            color: var(--text); margin: 0 0 16px;
        }
        .moon-lead {
            font-family: var(--font-vollkorn); font-size: var(--size-medium);
            line-height: 1.6; color: var(--text-muted); margin: 0; max-width: 40em;
        }

        .moon-bar { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 22px; }
        .moon-nav {
            font-family: var(--font-ui); font-size: 1.4rem; line-height: 1;
            width: 38px; height: 38px; border-radius: 10px;
            border: 1px solid var(--line); background: var(--card-bg);
            color: var(--text-muted); cursor: pointer; transition: 0.2s;
        }
        .moon-nav:hover { color: var(--accent); border-color: var(--accent); }
        .moon-label {
            font-family: var(--font-display); font-size: var(--size-h2);
            color: var(--text); margin: 0; min-width: 9em; text-align: center; text-transform: capitalize;
        }

        .moon-weekdays {
            display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; margin-bottom: 8px;
            font-family: var(--font-ui); font-size: var(--size-small);
            color: var(--color-text-faint); text-transform: uppercase; letter-spacing: 0.04em;
        }
        .moon-weekdays > div { text-align: center; }

        .moon-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; min-height: 360px; }
        .moon-loading {
            grid-column: 1 / -1; display: flex; align-items: center; justify-content: center;
            font-family: var(--font-ui); font-size: var(--size-small); color: var(--color-text-faint);
            padding: 60px 0;
        }

        .mc {
            position: relative; aspect-ratio: 1 / 1;
            border: 1px solid var(--line); border-radius: 12px; background: var(--card-bg);
            padding: 8px; display: flex; flex-direction: column; cursor: pointer;
            transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s; overflow: hidden;
        }
        .mc:hover { border-color: var(--accent); box-shadow: 0 8px 22px var(--shadow); transform: translateY(-2px); }
        .mc.empty { border: none; background: none; cursor: default; }
        .mc.empty:hover { box-shadow: none; transform: none; }
        .mc.is-selected { border-color: var(--accent); box-shadow: 0 8px 22px var(--shadow); }
        .mc.corridor { background: color-mix(in srgb, var(--accent) 7%, var(--card-bg)); }
        .mc.today {
            border-color: var(--accent);
            background: color-mix(in srgb, var(--accent) 10%, var(--card-bg));
        }

        .mc-top { display: flex; align-items: flex-start; justify-content: space-between; }
        .mc-date { font-family: var(--font-ui); font-size: var(--size-small); font-weight: 600; color: var(--text); }
        .mc.today .mc-date {
            background: var(--accent); color: var(--card-bg); border-radius: 50%;
            width: 1.5em; height: 1.5em; display: inline-flex; align-items: center; justify-content: center;
        }
        .mc-moonwrap { display: flex; align-items: center; gap: 4px; }
        .mc-moon { width: 26px; height: 26px; display: block; flex: 0 0 auto; }
        .mc-moon svg { display: block; width: 100%; height: 100%; }
        .mc-arrow { font-size: 0.85rem; color: var(--color-text-faint); line-height: 1; position: relative; top: -1.5px; }

        /* нижний блок ячейки: фаза → затмение → луна без курса (VoC внизу), слева */
        .mc-bottom { margin-top: auto; display: flex; flex-direction: column; align-items: flex-start; gap: 2px; padding-bottom: 4px; }
        .mc-phase {
            font-family: var(--font-ui); font-size: 0.62rem; font-weight: 600;
            letter-spacing: 0.02em; text-transform: uppercase; color: var(--accent-2); line-height: 1.2;
        }
        .mc-ecl { font-family: var(--font-ui); font-size: 0.58rem; font-weight: 700; color: #b4671f; line-height: 1.2; }
        .mc-voc { font-family: var(--font-ui); font-size: 0.57rem; line-height: 1.25; color: var(--color-text-faint); }

        /* ретрограды — цветные полосы по нижнему краю (тянутся через дни периода) */
        .mc-stripes { position: absolute; left: 0; right: 0; bottom: 0; display: flex; flex-direction: column; z-index: 1; }
        .mc-stripe { width: 100%; height: 4px; }

        .moon-detail { padding: 22px 24px; border: 1px solid var(--line); border-radius: 14px; background: var(--card-bg); animation: moon-slide-r 0.28s ease both; }
        @keyframes moon-slide-r { from { opacity: 0; transform: translateX(16px); } to { opacity: 1; transform: none; } }
        .md-date { font-family: var(--font-ui); font-size: var(--size-small); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--accent-2); margin: 0 0 12px; }
        .md-row { display: flex; align-items: center; gap: 14px; margin-bottom: 10px; }
        .md-moon { width: 46px; height: 46px; flex: 0 0 auto; }
        .md-phase { font-family: var(--font-vollkorn); font-size: var(--size-h3); color: var(--text); }
        .md-sub { font-family: var(--font-ui); font-size: var(--size-small); color: var(--text-muted); }
        .md-events { font-family: var(--font-vollkorn); font-size: var(--size-base); color: var(--text-muted); margin: 6px 0 0; }
        .md-events strong { color: var(--text); font-weight: 600; }

        /* заметка «нельзя планировать» — слева, рыжим акцентом */
        .moon-note {
            padding: 20px 22px; border-radius: 14px;
            border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--line));
            background: color-mix(in srgb, var(--accent) 8%, var(--card-bg));
            animation: moon-slide-l 0.28s ease both;
        }
        @keyframes moon-slide-l { from { opacity: 0; transform: translateX(-16px); } to { opacity: 1; transform: none; } }
        .mn-head { font-family: var(--font-ui); font-size: var(--size-small); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--accent); margin: 0 0 8px; display: flex; align-items: center; gap: 6px; }
        .mn-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
        .mn-list li { font-family: var(--font-vollkorn); font-size: var(--size-base); line-height: 1.5; color: var(--text-muted); }
        .mn-list li strong { color: var(--text); font-weight: 600; }
        .mn-dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; margin-right: 5px; vertical-align: middle; }

        .moon-legend {
            display: flex; flex-wrap: wrap; gap: 18px; margin-top: 26px; padding-top: 18px;
            border-top: 1px solid var(--line); font-family: var(--font-ui); font-size: var(--size-small); color: var(--text-muted);
        }
        .moon-legend span { display: inline-flex; align-items: center; gap: 6px; }
        .lg-dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }
        .lg-ecl { background: #b4671f; }
        .lg-bar { width: 5px; height: 14px; border-radius: 2px; display: inline-block; vertical-align: middle; margin-left: 4px; }
        .lg-arrow { color: var(--color-text-faint); }

        /* нет места по бокам (сетка 1000 + карточки) — панели складываются под календарь */
        @media (max-width: 1680px) {
            .moon.has-panel { max-width: 1000px; }
            .moon-stage { flex-wrap: wrap; }
            .moon-calendar { order: -1; width: 100%; flex-basis: 100%; }
            .moon-note, .moon-detail { flex: 1 1 260px; margin-top: 18px; }
        }

        @media (max-width: 760px) {
            .mc { border-radius: 9px; padding: 5px; }
            .mc-moon { width: 20px; height: 20px; }
            .mc-phase, .mc-voc, .mc-ecl { display: none; }
            .moon-grid, .moon-weekdays { gap: 5px; }
        }

        /* ── Печать ── */
        .moon-toolbar { display: flex; justify-content: center; margin-top: 24px; }
        .moon-print-btn {
            font-family: var(--font-ui); font-size: var(--size-small); font-weight: 600;
            color: var(--text-muted); background: var(--card-bg);
            border: 1px solid var(--line); border-radius: 999px; padding: 8px 18px; cursor: pointer;
            transition: 0.2s;
        }
        .moon-print-btn:hover { color: var(--accent); border-color: var(--accent); }
        .moon-overlay {
            position: fixed; inset: 0; z-index: 2000;
            display: flex; align-items: center; justify-content: center;
            background: color-mix(in srgb, var(--bg) 80%, transparent);
            font-family: var(--font-ui); font-size: var(--size-medium); color: var(--text);
        }
        .moon-overlay[hidden] { display: none; }
        .moon-print { display: none; }

        @media print {
            @page { size: A4 landscape; margin: 0; }
            /* печатаем точные цвета */
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
            /* прячем всё, кроме контейнера печати; .moon целиком — иначе его пустой бокс + верхний padding шапки даёт разрыв на первой странице */
            .site-header, .site-footer, .moon, .moon-overlay { display: none !important; }
            /* убираем отступ под фикс-шапку — из-за него «Январь» уезжал вниз только на первой странице */
            .main-content { padding: 0 !important; }
            .moon-print { display: block !important; }
            .print-month { page-break-after: always; padding: 14mm; box-sizing: border-box; }
            .print-month:last-child { page-break-after: auto; }
            .pm-title {
                font-family: var(--font-display); font-size: 1.6rem; font-weight: 700;
                text-transform: capitalize; margin: 0 0 8px; color: #1a1a1a;
            }
            .pm-grid { min-height: 0; gap: 4px; }
            .pm-grid .mc, .print-month .mc { aspect-ratio: auto; min-height: 92px; break-inside: avoid; }
            .print-month .mc:hover { transform: none; box-shadow: none; }

            /* финальная страница «Обозначения и правила» */
            .print-legend .pl-cols { display: grid; grid-template-columns: 1fr 1.2fr; gap: 24px; margin-top: 6px; }
            .print-legend .pl-h { font-family: var(--font-ui); font-size: 0.95rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #b4671f; margin: 0 0 10px; }
            .print-legend .pl-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
            .print-legend .pl-list li { font-family: var(--font-vollkorn); font-size: 0.86rem; line-height: 1.4; color: #1a1a1a; }
            .print-legend .pl-list strong { font-weight: 700; }
            .print-legend .pl-ic { display: inline-flex; align-items: center; gap: 3px; font-family: var(--font-ui); font-weight: 600; margin-right: 4px; }
            .print-legend .pl-ecl { width: 9px; height: 9px; border-radius: 50%; background: #b4671f; }
            .print-legend .pl-bar { width: 5px; height: 13px; border-radius: 2px; display: inline-block; vertical-align: middle; margin-right: 3px; }
            .print-legend .pl-rx { white-space: nowrap; }
        }
    </style>

    <script>
        import * as Astronomy from 'astronomy-engine';
        const B = Astronomy.Body;

        const MONTHS = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
        const MONTHS_GEN = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];
        const WD = ['воскресенье','понедельник','вторник','среда','четверг','пятница','суббота'];
        const QNAME = ['Новолуние','Первая четверть','Полнолуние','Последняя четверть'];
        const VOC_BODIES = [B.Sun, B.Mercury, B.Venus, B.Mars, B.Jupiter, B.Saturn];
        const PLANETS = [['Меркурий','☿',B.Mercury], ['Венера','♀',B.Venus], ['Марс','♂',B.Mars]];
        const RXCOLOR = { 'Меркурий': '#e0a93f', 'Венера': '#ec5fa0', 'Марс': '#5b9bd5' };
        const RX_GEN = { 'Меркурий': 'Меркурия', 'Венера': 'Венеры', 'Марс': 'Марса' };
        const RX_ADVICE = {
            'Меркурий': 'не подписывать договоры, не покупать технику, перепроверять письма, билеты и даты; хорошо доделывать и возвращаться к старому',
            'Венера': 'не начинать отношения, не заключать брак, не делать крупных покупок «для красоты» и не менять внешность (стрижка, косметология)',
            'Марс': 'не начинать новые дела и спорт «с нуля», не идти на конфликт, беречься от травм и плановых операций; сбавить темп',
        };
        const ASPECTS = [0, 60, 90, 120, 180];

        const norm = (x) => ((x % 360) + 360) % 360;
        const angd = (a) => { a = ((a + 180) % 360 + 360) % 360 - 180; return a; };
        const DAY = 86400000;

        // геоцентрическая эклиптич. долгота «от даты» (тропический зодиак)
        function glon(body, t) {
            const d = new Date(t);
            if (body === B.Sun) return Astronomy.SunPosition(d).elon;
            if (body === B.Moon) return Astronomy.EclipticGeoMoon(d).lon;
            const v = Astronomy.GeoVector(body, d, true);
            const e = Astronomy.RotateVector(Astronomy.Rotation_EQJ_ECT(d), v);
            return norm(Astronomy.SphereFromVector(e).lon);
        }
        const minSep = (ml, bl) => Math.abs(angd(ml - bl));
        function bisect(f, a, b) { let fa = f(a); for (let k = 0; k < 26; k++) { const m = (a + b) / 2, fm = f(m); if ((fa < 0) === (fm < 0)) { a = m; fa = fm; } else b = m; } return (a + b) / 2; }

        // ── рисунок Луны (доля освещённости + рост/убыль) ──
        function moonSVG(illum, waxing) {
            const R = 50, C = 50, dark = '#33333b', lit = '#ece3cf', ring = 'rgba(0,0,0,0.18)';
            if (illum < 0.015) return `<svg viewBox="0 0 100 100"><circle cx="${C}" cy="${C}" r="${R-1}" fill="${dark}" stroke="${ring}"/></svg>`;
            if (illum > 0.985) return `<svg viewBox="0 0 100 100"><circle cx="${C}" cy="${C}" r="${R-1}" fill="${lit}" stroke="${ring}"/></svg>`;
            const tx = R * Math.abs(1 - 2 * illum);
            const outer = waxing ? 1 : 0;
            const inner = illum > 0.5 ? outer : 1 - outer;
            const path = `M${C},${C-R} A${R},${R} 0 0 ${outer} ${C},${C+R} A${tx},${R} 0 0 ${inner} ${C},${C-R} Z`;
            return `<svg viewBox="0 0 100 100"><circle cx="${C}" cy="${C}" r="${R-1}" fill="${dark}"/><path d="${path}" fill="${lit}"/><circle cx="${C}" cy="${C}" r="${R-1}" fill="none" stroke="${ring}"/></svg>`;
        }

        // МСК-форматирование
        const mskParts = (t) => { const d = new Date(t + 3 * 3600000); return { day: d.getUTCDate(), mon: d.getUTCMonth(), hh: String(d.getUTCHours()).padStart(2,'0'), mm: String(d.getUTCMinutes()).padStart(2,'0') }; };
        const mskHM = (t) => { const p = mskParts(t); return `${p.hh}:${p.mm}`; };

        const cache = {};
        function computeMonth(y, m) {
            const k = y + '-' + m;
            if (cache[k]) return cache[k];
            const monthStartMs = Date.UTC(y, m, 1) - 3 * 3600000; // граница месяца по МСК → UTC
            const monthEndMs = Date.UTC(y, m + 1, 1) - 3 * 3600000;
            const daysIn = new Date(y, m + 1, 0).getDate();
            const days = {};
            for (let d = 1; d <= daysIn; d++) days[d] = { illum: 0, waxing: true, major: null, ecl: null, retros: [], voc: [] };

            // фаза/освещённость на полдень МСК
            for (let d = 1; d <= daysIn; d++) {
                const noon = Date.UTC(y, m, d, 12) - 3 * 3600000;
                const elong = norm(glon(B.Moon, noon) - glon(B.Sun, noon));
                days[d].illum = (1 - Math.cos(elong * Math.PI / 180)) / 2;
                days[d].waxing = elong < 180;
            }

            // мажорные фазы
            let mq = Astronomy.SearchMoonQuarter(new Date(monthStartMs));
            while (mq.time.date.getTime() < monthEndMs) {
                const p = mskParts(mq.time.date.getTime());
                if (mq.time.date.getTime() >= monthStartMs && days[p.day]) days[p.day].major = QNAME[mq.quarter];
                mq = Astronomy.NextMoonQuarter(mq);
            }

            // ретрограды (долгота убывает день-ко-дню)
            for (const [name, sym, body] of PLANETS) {
                let prev = glon(body, Date.UTC(y, m, 0, 12) - 3 * 3600000); // предыдущий день
                for (let d = 1; d <= daysIn; d++) {
                    const cur = glon(body, Date.UTC(y, m, d, 12) - 3 * 3600000);
                    if (angd(cur - prev) < 0) days[d].retros.push({ name, sym });
                    prev = cur;
                }
            }

            // затмения (± коридор) — ищем в расширенном окне
            const lo = monthStartMs - 12 * DAY, hi = monthEndMs + 12 * DAY;
            const eclList = [];
            let le = Astronomy.SearchLunarEclipse(new Date(lo));
            while (le.peak.date.getTime() < hi) { eclList.push({ t: le.peak.date.getTime(), type: 'Лунное' }); le = Astronomy.NextLunarEclipse(le.peak); }
            let se = Astronomy.SearchGlobalSolarEclipse(new Date(lo));
            while (se.peak.date.getTime() < hi) { eclList.push({ t: se.peak.date.getTime(), type: 'Солнечное' }); se = Astronomy.NextGlobalSolarEclipse(se.peak); }
            for (let d = 1; d <= daysIn; d++) {
                const dayMid = Date.UTC(y, m, d, 12) - 3 * 3600000;
                for (const e of eclList) {
                    const ep = mskParts(e.t);
                    if (ep.day === d && ep.mon === m) days[d].ecl = e.type;
                    if (Math.abs(dayMid - e.t) <= 5.5 * DAY) days[d].corridor = true;
                }
            }

            // ── Луна без курса ──
            const wStart = monthStartMs - 2 * DAY, wEnd = monthEndMs + 2 * DAY, step = 2 * 3600000;
            const ingress = [];
            let psign = Math.floor(norm(glon(B.Moon, wStart)) / 30);
            for (let t = wStart + step; t <= wEnd; t += step) {
                const s = Math.floor(norm(glon(B.Moon, t)) / 30);
                if (s !== psign) {
                    const bnd = ((psign + 1) % 12) * 30;
                    ingress.push(bisect((tt) => angd(norm(glon(B.Moon, tt)) - bnd), t - step, t));
                }
                psign = s;
            }
            const asps = [];
            for (const bd of VOC_BODIES) for (const ang of ASPECTS) {
                let pf = minSep(glon(B.Moon, wStart), glon(bd, wStart)) - ang;
                for (let t = wStart + step; t <= wEnd; t += step) {
                    const f = minSep(glon(B.Moon, t), glon(bd, t)) - ang;
                    if ((pf < 0) !== (f < 0)) asps.push(bisect((tt) => minSep(glon(B.Moon, tt), glon(bd, tt)) - ang, t - step, t));
                    pf = f;
                }
            }
            asps.sort((a, b) => a - b);
            for (const tj of ingress) {
                if (tj < monthStartMs || tj >= monthEndMs) continue;
                let start = null;
                for (const a of asps) { if (a < tj) start = a; else break; }
                if (start == null) continue;
                const sp = mskParts(start), ep = mskParts(tj);
                const endTxt = (sp.day === ep.day) ? mskHM(tj) : `${ep.day}.${String(ep.mon + 1).padStart(2, '0')} ${mskHM(tj)}`;
                if (days[sp.day]) days[sp.day].voc.push({ text: `${mskHM(start)} → ${endTxt}` });
            }

            cache[k] = { days, daysIn };
            return cache[k];
        }

        // ── Рендер ──
        let year = new Date().getFullYear(), month = new Date().getMonth();
        const grid = document.getElementById('moon-grid');
        const label = document.getElementById('moon-label');
        const today = new Date(); today.setHours(0, 0, 0, 0);
        const notePanel = document.getElementById('moon-note');
        const detailPanel = document.getElementById('moon-detail');

        function cellHTML(d, info) {
            return `
                ${info.retros.length ? `<div class="mc-stripes">${info.retros.map(r => `<span class="mc-stripe" style="background:${RXCOLOR[r.name] || '#ddd'}"></span>`).join('')}</div>` : ''}
                <div class="mc-top">
                    <span class="mc-date">${d}</span>
                    <span class="mc-moonwrap">
                        <span class="mc-arrow">${info.waxing ? '↗' : '↘'}</span>
                        <span class="mc-moon">${moonSVG(info.illum, info.waxing)}</span>
                    </span>
                </div>
                <div class="mc-bottom">
                    ${info.major ? `<div class="mc-phase">${info.major}</div>` : ''}
                    ${info.ecl ? `<div class="mc-ecl">${info.ecl} затмение</div>` : ''}
                    ${info.voc.length ? `<div class="mc-voc">🌙 ${info.voc.map(v => v.text).join('<br>')}</div>` : ''}
                </div>
            `;
        }

        function buildGrid(gridEl, y, m, data, interactive) {
            gridEl.innerHTML = '';
            const lead = (new Date(y, m, 1).getDay() + 6) % 7;
            for (let i = 0; i < lead; i++) { const e = document.createElement('div'); e.className = 'mc empty'; gridEl.appendChild(e); }
            for (let d = 1; d <= data.daysIn; d++) {
                const info = data.days[d];
                const cell = document.createElement('div');
                cell.className = 'mc';
                if (info.corridor) cell.classList.add('corridor');
                if (interactive && +new Date(y, m, d) === +today) cell.classList.add('today');
                cell.innerHTML = cellHTML(d, info);
                if (interactive) cell.addEventListener('click', () => selectDay(cell, d, info));
                gridEl.appendChild(cell);
            }
        }

        function render() {
            label.textContent = `${MONTHS[month]} ${year}`;
            grid.innerHTML = '<div class="moon-loading">Считаю фазы…</div>';
            notePanel.hidden = true; detailPanel.hidden = true;
            document.querySelector('.moon').classList.remove('has-panel');
            requestAnimationFrame(() => requestAnimationFrame(() => {
                buildGrid(grid, year, month, computeMonth(year, month), true);
            }));
        }

        // ── Печать всего года (месяц на страницу) ──
        const WD_SHORT = ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'];
        async function printYear() {
            const overlay = document.getElementById('moon-overlay');
            const pc = document.getElementById('moon-print');
            overlay.hidden = false;
            pc.innerHTML = '';
            for (let m = 0; m < 12; m++) {
                const data = computeMonth(year, m);
                const block = document.createElement('section');
                block.className = 'print-month';
                block.innerHTML = `
                    <h2 class="pm-title">${MONTHS[m]} ${year}</h2>
                    <div class="moon-weekdays pm-wd">${WD_SHORT.map(w => `<div>${w}</div>`).join('')}</div>
                    <div class="moon-grid pm-grid"></div>`;
                buildGrid(block.querySelector('.pm-grid'), year, m, data, false);
                pc.appendChild(block);
                await new Promise((r) => requestAnimationFrame(r)); // не морозим UI
            }
            // финальная страница — обозначения и что нельзя делать в особые дни
            const legend = document.createElement('section');
            legend.className = 'print-month print-legend';
            legend.innerHTML = `
                <h2 class="pm-title">Обозначения и правила</h2>
                <div class="pl-cols">
                    <div class="pl-block">
                        <h3 class="pl-h">Обозначения</h3>
                        <ul class="pl-list">
                            <li><span class="pl-ic">↗ / ↘</span> Луна растёт / убывает</li>
                            <li><span class="pl-ic">🌙</span> Луна без курса (интервал по МСК)</li>
                            <li><span class="pl-ic pl-ecl"></span> затмение (солнечное / лунное)</li>
                            <li>ретроград — полоса по нижнему краю дня:<br>
                                <span class="pl-rx"><span class="pl-bar" style="background:#e0a93f"></span>☿ Меркурий</span>,
                                <span class="pl-rx"><span class="pl-bar" style="background:#ec5fa0"></span>♀ Венера</span>,
                                <span class="pl-rx"><span class="pl-bar" style="background:#5b9bd5"></span>♂ Марс</span></li>
                        </ul>
                    </div>
                    <div class="pl-block">
                        <h3 class="pl-h">Чего лучше не делать в эти дни</h3>
                        <ul class="pl-list">
                            <li><strong><span class="pl-bar" style="background:#e0a93f"></span>Ретроград Меркурия ☿</strong> — не подписывать договоры, не покупать технику и гаджеты, перепроверять письма, билеты и даты. Хорошо: перечитывать, доделывать, возвращаться к старому.</li>
                            <li><strong><span class="pl-bar" style="background:#ec5fa0"></span>Ретроград Венеры ♀</strong> — не начинать отношения, не заключать брак, не делать крупных покупок «для красоты» и не менять внешность (стрижка, косметология). Хорошо: пересмотреть бюджет и вкусы.</li>
                            <li><strong><span class="pl-bar" style="background:#5b9bd5"></span>Ретроград Марса ♂</strong> — не начинать новые дела и спорт «с нуля», не идти на конфликт, беречься от травм и плановых операций. Хорошо: сбавить темп, доделывать начатое.</li>
                            <li><strong>Луна без курса 🌙</strong> — не начинать важное, переносить встречи и сделки. Подходит для рутины, отдыха и «дел в стол».</li>
                            <li><strong>Затмение</strong> — не принимать резких решений и не начинать крупное, беречь силы.</li>
                            <li><strong>Новолуние</strong> — время намерений и планов, но не активного старта. <strong>Полнолуние</strong> — пик эмоций, лучше без важных решений.</li>
                        </ul>
                    </div>
                </div>`;
            pc.appendChild(legend);
            overlay.hidden = true;
            window.print();
        }

        function selectDay(cell, d, info) {
            grid.querySelectorAll('.mc.is-selected').forEach((c) => c.classList.remove('is-selected'));
            cell.classList.add('is-selected');
            document.querySelector('.moon').classList.add('has-panel');

            const dateObj = new Date(year, month, d);
            const phaseName = info.major || (info.waxing ? 'Растущая Луна' : 'Убывающая Луна');
            const pct = Math.round(info.illum * 100);

            // правая панель — дата и фаза
            detailPanel.innerHTML = `
                <p class="md-date">${d} ${MONTHS_GEN[month]} ${year} · ${WD[dateObj.getDay()]}</p>
                <div class="md-row">
                    <span class="md-moon">${moonSVG(info.illum, info.waxing)}</span>
                    <span><span class="md-phase">${phaseName}</span><br>
                    <span class="md-sub">освещена на ${pct}% · ${info.waxing ? 'растёт' : 'убывает'}</span></span>
                </div>`;
            detailPanel.hidden = false;
            detailPanel.style.animation = 'none'; void detailPanel.offsetWidth; detailPanel.style.animation = '';

            // левая панель — предупреждение «нельзя планировать» (ретроград / Луна без курса / затмение)
            const warns = [];
            if (info.ecl) warns.push(`<strong><span class="mn-dot" style="background:#b4671f"></span>${info.ecl} затмение</strong> — резкие события, лучше ничего не начинать`);
            info.retros.forEach(r => warns.push(`<strong><span class="mn-dot" style="background:${RXCOLOR[r.name] || '#ddd'}"></span>Ретроград ${RX_GEN[r.name] || r.name}</strong> — ${RX_ADVICE[r.name] || 'не начинать новое, доделывать старое'}`));
            if (info.voc.length) warns.push(`<strong><span class="mn-dot" style="background:var(--accent-2)"></span>Луна без курса</strong> (${info.voc.map(v => v.text).join('; ')}) — дела «в стол», без важных решений`);

            if (warns.length) {
                notePanel.innerHTML = `
                    <p class="mn-head">⚠ Не планировать важное</p>
                    <ul class="mn-list">${warns.map(w => `<li>${w}</li>`).join('')}</ul>`;
                notePanel.hidden = false;
                notePanel.style.animation = 'none'; void notePanel.offsetWidth; notePanel.style.animation = '';
            } else {
                notePanel.hidden = true;
            }
        }

        document.querySelectorAll('.moon-nav').forEach((b) => {
            b.addEventListener('click', () => {
                month += b.dataset.step === 'next' ? 1 : -1;
                if (month < 0) { month = 11; year--; }
                if (month > 11) { month = 0; year++; }
                render();
            });
        });

        const printBtn = document.getElementById('moon-print-btn');
        if (printBtn) printBtn.addEventListener('click', printYear);

        render();
    </script>
</BaseLayout>
