                                </svg>
                            </div>
                            <div class="icon-hover">
                                <div class="icon-brackets">
                                    <svg class="bracket-left" width="14" height="28" viewBox="0 0 34 67" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M24.2358 41.504L15.1124 36.9609L12.7891 46.6011L24.2435 56.9979L24.2358 41.504Z" fill="#7D5C3F"/>
                                        <path d="M0 33.0008L10.5012 44.3374L20.2383 42.0411L15.6496 33.0008L20.2383 23.9604L10.5012 21.6641L0 33.0008Z" fill="#7D5C3F"/>
