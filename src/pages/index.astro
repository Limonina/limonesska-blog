                                    </svg>
                                </div>
                            </div>
                        </div>
                        <div class="menu-text">
                            <span class="menu-title">Проекты</span>
                            <span class="menu-desc">Что-то построенное. Что-то строится. А что-то даже не знает, чем закончится</span>
                        </div>
                    </a>

                    <a href="/blog" class="menu-item">
                        <div class="menu-icon">
                            <svg width="28" height="28" viewBox="0 0 67 67" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <g clip-path="url(#clip-menu-star-max)">
                                    <path d="M39.5459 54.8692L33.4717 66.9551L27.3936 54.8702L33.4697 51.8028L39.5459 54.8692Z" fill="#7D5C3F"/>
