---
import { getEntries } from '../utils/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const sortByDate = (a, b) => +b.data.pubDate - +a.data.pubDate;

const blogPosts = (await getEntries('blog')).sort(sortByDate);
const notes = (await getEntries('notes')).sort(sortByDate);

const latestPosts = blogPosts.slice(0, 4);
const freshNotes = notes.slice(0, 3);

const formatDate = (date) =>
  date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title="limonesska | Моя броня">

    <section class="top-section">

        <div class="intro-block">
            <h1 class="hero-title">Строю системы там, где другие видят хаос.</h1>
            <p class="hero-subtitle">
                Управление данными, дизайн смыслов и непрерывное обучение.
                Добро пожаловать в мою броню — здесь мысли-чешуйки собираются в систему, которая держит.
            </p>
            <div class="button-group">
                <a href="/blog" class="btn-primary">Читать блог</a>
                <a href="/about" class="btn-secondary">Обо мне</a>
            </div>

            <div class="tags-block">
                <div class="tags-header">Популярные темы</div>
                <div class="tags-list">
                    <a href="#" class="tag-pill">#систематизация</a>
                    <a href="#" class="tag-pill">#дизайн-смыслов</a>
                    <a href="#" class="tag-pill">#инди-хакер</a>
                    <a href="#" class="tag-pill">#astro-build</a>
                </div>
            </div>
        </div>

        <a href="/blog/moving-to-astro" class="popular-card">
            <img src="https://images.unsplash.com/photo-1586075010923-2dd4570fb338?q=80&w=800&auto=format&fit=crop" class="popular-bg-img" alt="System" />

            <div class="popular-overlay-content">
                <span class="post-tag">Популярное</span>
                <h3>Сжигаю мосты: почему я ухожу с WordPress на Astro</h3>
                <p>Отказ от тяжелых баз данных в пользу легкости текстовых файлов.</p>
                <div class="popular-author-meta">
                    by <span class="author-name">Limonesska</span> • 16 мая 2026
                </div>
            </div>
        </a>

        <div class="editors-column">
            <h3 class="column-title">Свежие заметки</h3>

            {freshNotes.map((note) => (
                <a href={`/notes/${note.id}`} class="editors-card editors-card--note">
                    <div class="editors-card-content">
                        {note.data.tags.length > 0 && <span class="side-tag">#{note.data.tags[0]}</span>}
                        <h4>{note.data.title}</h4>
                        <span class="editors-date">{formatDate(note.data.pubDate)}</span>
                    </div>
                </a>
            ))}

            <div class="quote-widget">
                <div class="quote-icon">“</div>
                <div class="quote-text">За каждой красивой и работающей системой всегда стоят часы структурированного хаоса.</div>
                <div class="quote-author">— Limonesska</div>
            </div>
        </div>

    </section>

    <section class="latest-section">
        <div class="section-header-flex">
            <h2>Новые статьи</h2>
            <a href="/blog" class="view-all-link">
                Все статьи <span>→</span>
            </a>
        </div>

        <div class="latest-grid">
            {latestPosts.map((post) => <PostCard post={post} />)}
        </div>
    </section>

</BaseLayout>

<style is:global>
    /* --- ВЕРХНИЙ БЛОК --- */
    .top-section {
        display: grid;
        grid-template-columns: 1.4fr 1.1fr 0.9fr;
        gap: 40px; margin-bottom: 80px; align-items: start;
    }

    /* 1. ЛЕВАЯ КОЛОНКА */
    .intro-block { display: flex; flex-direction: column; height: 600px; justify-content: flex-start; }

    .hero-title {
        font-family: var(--font-display); font-size: var(--size-mega);
        font-weight: 700; line-height: 1.1; margin: 0 0 25px 0; letter-spacing: -1px; color: var(--color-text);
    }

    .hero-subtitle {
        font-family: var(--font-vollkorn); font-size: var(--size-base);
        color: var(--color-text-soft); line-height: 1.6; margin: 0;
    }

    .button-group { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 40px; margin-bottom: 50px; font-family: var(--font-ui); }
    .btn-primary { background: var(--text); color: var(--color-surface); border: 1px solid var(--text); padding: 14px 28px; border-radius: 8px; text-decoration: none; font-size: var(--size-medium); font-weight: 600; transition: 0.2s; text-align: center; }
    .btn-primary:hover { background: var(--text-muted); border-color: var(--text-muted); }
    .btn-secondary { background: var(--color-surface); color: var(--text); border: 1px solid var(--line); padding: 14px 28px; border-radius: 8px; text-decoration: none; font-size: var(--size-medium); font-weight: 600; transition: 0.2s; text-align: center; }
    .btn-secondary:hover { border-color: var(--text-muted); background: var(--bg); }

    .tags-block { margin-top: auto; padding-bottom: 25px; font-family: var(--font-ui); }
    .tags-header { font-size: var(--size-medium); font-weight: 700; color: var(--color-text); margin-bottom: 16px; }
    .tags-list { display: flex; gap: 10px; flex-wrap: wrap; }

    .tag-pill {
        background: var(--color-surface); border: 1px solid var(--color-border); padding: 8px 16px; border-radius: 20px;
        font-size: var(--size-small); font-weight: 500; text-decoration: none; color: var(--color-text-soft); transition: 0.2s;
    }
    .tag-pill:hover { background: var(--text); color: var(--color-surface); border-color: var(--text); }

    /* 2. ЦЕНТРАЛЬНАЯ КАРТОЧКА */
    .popular-card {
        position: relative; background: var(--color-surface); border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; transition: 0.3s;
        height: 600px; width: 100%; display: flex;
    }
    .popular-bg-img { width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 1; }
    .popular-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 60%; background: linear-gradient(to top, rgba(0,0,0,0.3), transparent); z-index: 2; }

    .popular-overlay-content {
        position: absolute; bottom: 60px; left: 30px; width: calc(100% - 48px); max-width: 310px;
        background: var(--color-surface); padding: 24px; border-radius: 12px;
        box-shadow: 0 10px 25px var(--shadow); z-index: 3;
        display: flex; flex-direction: column; gap: 8px;
    }

    .post-tag {
        font-family: var(--font-ui); font-size: var(--size-small);
        font-weight: 700; color: var(--color-text-muted); display: inline-block; text-transform: uppercase; letter-spacing: 1px;
    }
    .popular-overlay-content h3 { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-medium); line-height: 1.3; font-weight: 700; color: var(--color-text); }
    .popular-overlay-content p { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-base); color: var(--color-text-soft); line-height: 1.5; }

    .popular-author-meta { font-family: var(--font-ui); font-size: var(--size-small); color: var(--color-text-faint); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .author-name { color: var(--color-text); font-weight: 700; }

    /* 3. ПРАВАЯ КОЛОНКА */
    .editors-column { display: flex; flex-direction: column; gap: 16px; height: 600px; }
    .column-title { font-family: var(--font-ui); font-size: var(--size-medium); font-weight: 700; color: var(--color-text); margin: 0 0 5px 0; border-bottom: 1px solid var(--color-border); padding-bottom: 8px; }

    .editors-card { display: flex; gap: 16px; align-items: center; text-decoration: none; color: inherit; padding: 8px; border-radius: 12px; transition: 0.25s; }
    .editors-card:hover { background: rgba(0, 0, 0, 0.03); transform: translateX(3px); }
    html[data-theme="dark"] .editors-card:hover { background: rgba(255, 255, 255, 0.08); }
    .editors-card img { width: 85px; height: 115px; border-radius: 8px; object-fit: cover; flex-shrink: 0; border: 1px solid var(--line); }
    .editors-card-content { display: flex; flex-direction: column; gap: 4px; }

    .side-tag { font-family: var(--font-ui); font-size: var(--size-small); text-transform: uppercase; font-weight: 700; color: var(--color-text-muted); display: block; letter-spacing: 1px;}

    .editors-card h4 { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-base); line-height: 1.3; font-weight: 700; color: var(--color-text); }
    .editors-date { font-family: var(--font-ui); font-size: var(--size-small); color: var(--color-text-faint); text-transform: uppercase; letter-spacing: 0.5px; }

    .quote-widget { margin-top: auto; padding: 20px 10px; position: relative; }
    .quote-icon { font-family: var(--font-display); font-size: var(--size-mega); color: var(--color-border); position: absolute; top: -10px; left: 0; line-height: 1; z-index: 1; user-select: none; }
    .quote-text { font-family: var(--font-display); font-style: italic; font-size: var(--size-medium); font-weight: 700; color: var(--color-text); line-height: 1.5; position: relative; z-index: 2; padding-left: 10px; }
    .quote-author { font-family: var(--font-vollkorn); margin-top: 15px; padding-left: 10px; font-size: var(--size-base); color: var(--color-text-muted); }

    /* --- НОВЫЕ СТАТЬИ --- */
    .latest-section { margin-top: 150px; }

    .section-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .section-header-flex h2 { font-family: var(--font-ui); font-size: var(--size-medium); font-weight: 700; margin: 0; color: var(--color-text); }
    .view-all-link { font-family: var(--font-ui); display: flex; align-items: center; gap: 6px; color: var(--text); text-decoration: none; font-size: var(--size-base); font-weight: 600; transition: gap 0.2s; }
    .view-all-link:hover { gap: 10px; }

    .latest-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 80px; }
    .latest-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; transition: 0.3s; display: flex; flex-direction: column; }
    .latest-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px var(--shadow); border-color: var(--line); }

    .latest-card > img { width: 100%; height: 200px; object-fit: cover; border-bottom: 1px solid var(--color-border); }

    .latest-card-content { padding: 20px; display: flex; flex-direction: column; gap: 12px; flex-grow: 1; }
    .latest-card h3 { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-medium); font-weight: 700; line-height: 1.3; color: var(--color-text); }
    .latest-card p { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-base); color: var(--color-text-soft); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

    .latest-properties-footer { font-family: var(--font-ui); margin-top: auto; padding-top: 15px; border-top: 1px solid var(--color-border-soft); display: flex; justify-content: space-between; align-items: center; font-size: var(--size-small); color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.5px; }

    .properties-left { display: flex; align-items: center; }
    .dot-separator { margin: 0 8px; color: var(--color-text-faint); }
    .read-time-block { display: flex; align-items: center; gap: 6px; }

    .time-icon {
        width: 14px !important;
        height: 14px !important;
        min-width: 14px !important;
        flex-shrink: 0;
        color: var(--color-text-muted);
        border: none !important;
    }

    .bookmark-icon-btn { background: none; border: none; padding: 4px; color: var(--text-muted); cursor: pointer; transition: color 0.2s; display: flex; align-items: center; justify-content: center; }
    .bookmark-icon-btn:hover { color: var(--accent); }
    .bookmark-icon-btn svg {
        width: 18px !important;
        height: 18px !important;
        min-width: 18px !important;
        flex-shrink: 0;
    }

    @media (max-width: 1400px) { .latest-grid { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); } }
    @media (max-width: 1100px) {
        .top-section { grid-template-columns: 1fr 1fr; }
        .editors-column { grid-column: span 2; display: grid; grid-template-columns: 1fr 1fr; height: auto; }
        .quote-widget { grid-column: span 2; }
        .popular-card { height: 500px; }
    }
    @media (max-width: 768px) {
        .top-section { grid-template-columns: 1fr; gap: 40px; }
        .editors-column { grid-column: span 1; grid-template-columns: 1fr; }
        .quote-widget { grid-column: span 1; }
        .intro-block { height: auto; }
        .btn-primary, .btn-secondary { width: 100%; }
        .popular-card { height: 450px; }
    }
</style>
