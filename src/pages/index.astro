---
import { Image } from 'astro:assets';
import myLogo from '../assets/limonesska_logo.svg';
import timeIcon from '../assets/icons/time.svg';
---

<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/limonesska_logo_circle.svg" />
    <link rel="icon" href="/limonesska_logo_circle.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>limonesska | Цифровой сад</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&family=Vollkorn:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <style is:global>
        :root {
            /* 3 СТРОГИХ ШРИФТА */
            --font-display: 'Playfair Display', serif;
            --font-vollkorn: 'Vollkorn', serif;
            --font-ui: 'Manrope', sans-serif;

            /* 4 СТРОГИХ РАЗМЕРА */
            --size-mega: clamp(2.5rem, 4vw, 3.5rem); 
            --size-medium: 1.25rem;                  
            --size-base: 1rem;                       
            --size-small: 0.75rem;                   
        }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background: #fafafa;
            color: #1a1a1a;
            -webkit-font-smoothing: antialiased;
            font-size: 17px; 
            font-variant-numeric: lining-nums; 
        }
        *, *:before, *:after { box-sizing: border-box; }

        /* --- ШАПКА --- */
        .site-header {
            position: fixed; top: 14px; left: 24px; right: 24px; z-index: 100;
            display: flex; justify-content: space-between; align-items: center;
            padding: 18px 36px; background: rgba(250,250,250,0.75);
            backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border-radius: 14px;
            box-shadow: 0 6px 28px rgba(0,0,0,0.08);
            font-family: var(--font-ui); font-size: var(--size-base);
        }
        .logo-link { display: flex; align-items: center; text-decoration: none; }
        .logo-img { height: 40px; width: auto; }
        
        .dropdown { position: relative; display: inline-block; }
        .header-nav { display: flex; align-items: center; gap: 20px; }

        .garden-link {
            font-family: var(--font-ui); font-size: var(--size-base); font-weight: 600;
            text-decoration: none; color: #1a1a1a; position: relative; padding-bottom: 2px;
            background-image: linear-gradient(#FF5C00, #FF5C00), linear-gradient(#FF5C00, #FF5C00);
            background-position: left bottom, right bottom;
            background-size: 0% 1.5px, 0% 1.5px;
            background-repeat: no-repeat;
            transition: color 0.35s ease, background-size 0.4s ease;
        }
        .garden-link:hover {
            color: #FF5C00;
            background-size: 50% 1.5px, 50% 1.5px;
        }

        .dropbtn {
            background: none; border: none; cursor: pointer; padding: 8px;
            color: #1a1a1a; transition: color 0.35s ease;
            display: flex; align-items: center; justify-content: center;
            border-radius: 8px; perspective: 400px;
        }
        .dropbtn:hover { color: #FF5C00; }
        .menu-chevron { transition: transform 0.65s ease; display: block; }
        .dropbtn:hover .menu-chevron { transform: rotateY(180deg); }
        .dropdown-content {
            display: none; position: absolute; right: 0; background-color: #fff;
            min-width: 560px;
            box-shadow: 0px 12px 40px rgba(0,0,0,0.08); border-radius: 16px; z-index: 10;
            border: 1px solid #eaeaea; padding: 8px;
        }
        .dropdown.is-open .dropdown-content { display: block; }

        .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
        .menu-item {
            display: flex; align-items: flex-start; gap: 14px; padding: 14px 16px;
            border-radius: 10px; text-decoration: none; color: inherit;
            transition: transform 0.4s ease, background 0.4s ease;
        }
        .menu-item:hover { background: rgba(0,0,0,0.03); transform: translateY(-1px); }
        .menu-item:hover .menu-title { color: #FF5C00; }
        .menu-icon {
            width: 32px; height: 32px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; position: relative;
            transition: transform 0.4s ease;
        }
        .menu-item:hover .menu-icon { transform: scale(1.08); }
        .menu-text { display: flex; flex-direction: column; }
        .menu-title {
            font-family: var(--font-ui); font-weight: 600; font-size: var(--size-base);
            color: #1a1a1a; transition: color 0.4s ease; display: block; margin-bottom: 4px;
        }
        .menu-desc {
            font-family: var(--font-vollkorn); font-size: 0.875rem; color: #888;
            line-height: 1.45; display: block;
        }
        .projects-icon .icon-default,
        .projects-icon .icon-hover {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center; transition: opacity 0.4s ease;
        }
        .projects-icon .icon-hover { opacity: 0; }
        .menu-item:hover .projects-icon .icon-default { opacity: 0; }
        .menu-item:hover .projects-icon .icon-hover { opacity: 1; }
        .icon-brackets { display: flex; align-items: center; gap: 3px; }
        .bracket-left { transition: transform 0.4s ease; transform: translateX(8px); }
        .bracket-right { transition: transform 0.4s ease; transform: translateX(-8px); }
        .menu-item:hover .bracket-left { transform: translateX(0); }
        .menu-item:hover .bracket-right { transform: translateX(0); }

        .main-content {
            max-width: 1600px; margin: 0 auto; width: 100%; padding: 150px 40px 60px;
        }

        /* --- ВЕРХНИЙ БЛОК --- */
        .top-section {
            display: grid;
            grid-template-columns: 1.4fr 1.1fr 0.9fr; 
            gap: 40px; margin-bottom: 80px; align-items: start;
        }

        /* 1. ЛЕВАЯ КОЛОНКА */
        .intro-block { display: flex; flex-direction: column; height: 600px; justify-content: flex-start; }
        
        .hero-title { 
            font-family: var(--font-display); font-size: var(--size-mega); 
            font-weight: 700; line-height: 1.1; margin: 0 0 25px 0; letter-spacing: -1px; color: #111;
        }
        
        .hero-subtitle { 
            font-family: var(--font-vollkorn); font-size: var(--size-base); 
            color: #444; line-height: 1.6; margin: 0; 
        }
        
        .button-group { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 40px; margin-bottom: 50px; font-family: var(--font-ui); }
        .btn-primary { background: #000; color: #fff; border: 1px solid #000; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-size: var(--size-medium); font-weight: 600; transition: 0.2s; text-align: center; }
        .btn-primary:hover { background: #333; border-color: #333; }
        .btn-secondary { background: #fff; color: #000; border: 1px solid #ddd; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-size: var(--size-medium); font-weight: 600; transition: 0.2s; text-align: center; }
        .btn-secondary:hover { border-color: #aaa; background: #f9f9f9; }

        .tags-block { margin-top: auto; padding-bottom: 25px; font-family: var(--font-ui); }
        .tags-header { font-size: var(--size-medium); font-weight: 700; color: #1a1a1a; margin-bottom: 16px; }
        .tags-list { display: flex; gap: 10px; flex-wrap: wrap; }
        
        .tag-pill {
            background: #fff; border: 1px solid #eaeaea; padding: 8px 16px; border-radius: 20px;
            font-size: var(--size-small); font-weight: 500; text-decoration: none; color: #444; transition: 0.2s;
        }
        .tag-pill:hover { background: #000; color: #fff; border-color: #000; }

        /* 2. ЦЕНТРАЛЬНАЯ КАРТОЧКА */
        .popular-card {
            position: relative; background: #fff; border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; transition: 0.3s;
            height: 600px; width: 100%; display: flex;
        }
        .popular-bg-img { width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 1; }
        .popular-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 60%; background: linear-gradient(to top, rgba(0,0,0,0.3), transparent); z-index: 2; }

        .popular-overlay-content {
            position: absolute; bottom: 60px; left: 30px; width: calc(100% - 48px); max-width: 310px; 
            background: #ffffff; padding: 24px; border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08); z-index: 3;
            display: flex; flex-direction: column; gap: 8px;
        }
        
        .post-tag { 
            font-family: var(--font-ui); font-size: var(--size-small); 
            font-weight: 700; color: #888; display: inline-block; text-transform: uppercase; letter-spacing: 1px;
        }
        .popular-overlay-content h3 { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-medium); line-height: 1.3; font-weight: 700; color: #1a1a1a; }
        .popular-overlay-content p { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-base); color: #555; line-height: 1.5; }
        
        .popular-author-meta { font-family: var(--font-ui); font-size: var(--size-small); color: #999; margin-top: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
        .author-name { color: #1a1a1a; font-weight: 700; } 

        /* 3. ПРАВАЯ КОЛОНКА */
        .editors-column { display: flex; flex-direction: column; gap: 16px; height: 600px; }
        .column-title { font-family: var(--font-ui); font-size: var(--size-medium); font-weight: 700; color: #1a1a1a; margin: 0 0 5px 0; border-bottom: 1px solid #eaeaea; padding-bottom: 8px; }
        
        .editors-card { display: flex; gap: 16px; align-items: center; text-decoration: none; color: inherit; padding: 8px; border-radius: 12px; transition: 0.25s; }
        .editors-card:hover { background: rgba(0, 0, 0, 0.03); transform: translateX(3px); }
        .editors-card img { width: 85px; height: 115px; border-radius: 8px; object-fit: cover; flex-shrink: 0; border: 1px solid #f0f0f0; }
        .editors-card-content { display: flex; flex-direction: column; gap: 4px; }
        
        .side-tag { font-family: var(--font-ui); font-size: var(--size-small); text-transform: uppercase; font-weight: 700; color: #888; display: block; letter-spacing: 1px;}
        
        .editors-card h4 { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-base); line-height: 1.3; font-weight: 700; color: #1a1a1a; }
        .editors-date { font-family: var(--font-ui); font-size: var(--size-small); color: #999; text-transform: uppercase; letter-spacing: 0.5px; }

        .quote-widget { margin-top: auto; padding: 20px 10px; position: relative; }
        .quote-icon { font-family: var(--font-display); font-size: 5rem; color: #eaeaea; position: absolute; top: -10px; left: 0; line-height: 1; z-index: 1; user-select: none; }
        .quote-text { font-family: var(--font-display); font-style: italic; font-size: var(--size-medium); font-weight: 700; color: #222; line-height: 1.5; position: relative; z-index: 2; padding-left: 10px; }
        .quote-author { font-family: var(--font-vollkorn); margin-top: 15px; padding-left: 10px; font-size: var(--size-base); color: #888; }

        /* --- НОВЫЕ СТАТЬИ --- */
        .latest-section { margin-top: 150px; }

        .section-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .section-header-flex h2 { font-family: var(--font-ui); font-size: var(--size-medium); font-weight: 700; margin: 0; color: #1a1a1a; }
        .view-all-link { font-family: var(--font-ui); display: flex; align-items: center; gap: 6px; color: #000; text-decoration: none; font-size: var(--size-base); font-weight: 600; transition: gap 0.2s; }
        .view-all-link:hover { gap: 10px; }

        .latest-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 80px; }
        .latest-card { background: #fff; border: 1px solid #eaeaea; border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; transition: 0.3s; display: flex; flex-direction: column; }
        .latest-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.04); border-color: #ddd; }
        
        .latest-card > img { width: 100%; height: 200px; object-fit: cover; border-bottom: 1px solid #eaeaea; }
        
        .latest-card-content { padding: 20px; display: flex; flex-direction: column; gap: 12px; flex-grow: 1; }
        .latest-card h3 { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-medium); font-weight: 700; line-height: 1.3; color: #1a1a1a; }
        .latest-card p { font-family: var(--font-vollkorn); margin: 0; font-size: var(--size-base); color: #555; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
        
        .latest-properties-footer { font-family: var(--font-ui); margin-top: auto; padding-top: 15px; border-top: 1px solid #f5f5f5; display: flex; justify-content: space-between; align-items: center; font-size: var(--size-small); color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
        
        .properties-left { display: flex; align-items: center; }
        .dot-separator { margin: 0 8px; color: #ccc; }
        .read-time-block { display: flex; align-items: center; gap: 6px; }
        
        .time-icon { 
            width: 14px !important; 
            height: 14px !important; 
            min-width: 14px !important; 
            flex-shrink: 0; 
            opacity: 0.7; 
            border: none !important;
        }
        
        .bookmark-icon-btn { background: none; border: none; padding: 4px; color: #aaa; cursor: pointer; transition: color 0.2s; display: flex; align-items: center; justify-content: center; }
        .bookmark-icon-btn:hover { color: #000; }
        .bookmark-icon-btn svg { 
            width: 18px !important; 
            height: 18px !important; 
            min-width: 18px !important;
            flex-shrink: 0;
        } 

        /* ПОДВАЛ */
        .site-footer { font-family: var(--font-ui); width: 100%; border-top: 1px solid #eaeaea; padding-top: 30px; display: flex; justify-content: space-between; font-size: var(--size-small); color: #999; }
        
        @media (max-width: 1400px) { .latest-grid { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); } }
        @media (max-width: 1100px) {
            .top-section { grid-template-columns: 1fr 1fr; }
            .editors-column { grid-column: span 2; display: grid; grid-template-columns: 1fr 1fr; height: auto; }
            .quote-widget { grid-column: span 2; }
            .popular-card { height: 500px; }
        }
        @media (max-width: 768px) {
            .main-content { padding: 110px 20px 40px; }
            .top-section { grid-template-columns: 1fr; gap: 40px; }
            .editors-column { grid-column: span 1; grid-template-columns: 1fr; }
            .quote-widget { grid-column: span 1; }
            .intro-block { height: auto; }
            .btn-primary, .btn-secondary { width: 100%; }
            .popular-card { height: 450px; }
            .site-footer { flex-direction: column; gap: 10px; text-align: center; }
        }
    </style>
</head>
<body>
    
    <header class="site-header">
        <a href="/" class="logo-link">
            <Image src={myLogo} alt="limonesska logo" class="logo-img" />
        </a>
        <div class="header-nav">
        <a href="/" class="garden-link">Мой сад</a>
        <div class="dropdown">
            <button class="dropbtn" id="menu-toggle" aria-label="Меню">
                <svg class="menu-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>
            <div class="dropdown-content">
                <div class="menu-grid">

                    <a href="/diary" class="menu-item">
                        <div class="menu-icon">
                            <svg width="28" height="28" viewBox="0 0 67 67" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M24.0541 14.0719L24.1498 17.1657L26.4462 15.6714L32.0482 19.7927V46.7236L32.0131 51.1826L12.9003 40.2243V43.1128L27.9076 52.5007V59L8 46.3625V17.1657L12.2974 19.6432L12.2878 7L24.0541 14.0719Z" fill="#7D5C3F"/>
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M54.7026 19.6432L59 17.1657V46.3625L39.0924 59V52.5007L54.0997 43.1128V40.2243L34.9167 51.1826L34.9518 46.7236V19.7927L40.5538 15.6714L42.8502 17.1657L42.9459 14.0719L54.7122 7L54.7026 19.6432Z" fill="#7D5C3F"/>
                            </svg>
                        </div>
                        <div class="menu-text">
                            <span class="menu-title">Дневник</span>
                            <span class="menu-desc">Хроника в реальном времени: рутина, поездки, игры и всё, что просто происходит</span>
                        </div>
                    </a>

                    <a href="/projects" class="menu-item">
                        <div class="menu-icon projects-icon">
                            <div class="icon-default">
                                <svg width="28" height="28" viewBox="0 0 67 67" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <g clip-path="url(#clip-menu-code)">
                                        <path d="M45.0751 46.6061L42.7293 36.9609L33.4966 41.5072L24.2717 36.9647L21.9297 46.6023L33.5043 57.0008L45.0751 46.6061Z" fill="#7D5C3F"/>
