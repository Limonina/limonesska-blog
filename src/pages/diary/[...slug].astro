---
import { render } from 'astro:content';
import { getEntries } from '../../utils/content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const entries = await getEntries('diary');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const words = entry.body ? entry.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(words / 150));

const fmt = (d) => d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });

// Чистый URL в photos → навешиваем оптимизацию здесь (как в календаре)
const cl = (url, t) =>
  url.includes('res.cloudinary.com/') ? url.replace('/upload/', `/upload/${t}/`) : url;
const photos = entry.data.photos ?? [];
---

<PostLayout
    title={entry.data.title ?? fmt(entry.data.pubDate)}
    description={entry.data.description}
    pubDate={entry.data.pubDate}
    updatedDate={entry.data.updatedDate}
    tags={entry.data.tags}
    category={entry.data.category}
    subcategory={entry.data.subcategory}
    stage={entry.data.stage}
    audience={entry.data.audience}
    readingTime={readingTime}
    backHref="/diary"
    backLabel="Дневник"
>
    {photos.length > 0 && (
        <div class="diary-photos">
            {photos.map((u) => (
                <img src={cl(u, 'f_auto,q_auto,w_1200')} alt="" loading="lazy" />
            ))}
        </div>
    )}
    <Content />
</PostLayout>

<style is:global>
    .diary-photos {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 28px;
    }
    .diary-photos img {
        width: 100%;
        border-radius: 12px;
        border: 1px solid var(--line);
    }
</style>
