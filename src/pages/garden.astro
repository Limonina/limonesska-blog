---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntries } from '../utils/content';
import Icon from '../components/Icon.astro';

const blog = await getEntries('blog');
const notes = await getEntries('notes');

type Item = {
  type: 'post' | 'note';
  typeLabel: string;
  title: string;
  href: string;
  date: Date;
  description?: string;
  coming?: boolean;
  stage?: 'base' | 'advanced' | 'max';
  cover?: string;
};

const items: Item[] = [
  ...blog.map((p) => ({
    type: 'post' as const,
    typeLabel: 'Статья',
    title: p.data.title,
    href: `/blog/${p.id}`,
    date: p.data.pubDate,
    description: p.data.description,
    coming: p.data.coming,
    stage: p.data.stage,
    cover: p.data.cover,
  })),
  ...notes.map((n) => ({
    type: 'note' as const,
    typeLabel: 'Заметка',
    title: n.data.title,
    href: `/notes/${n.id}`,
    date: n.data.pubDate,
    description: n.data.description,
    coming: n.data.coming,
    stage: n.data.stage,
    cover: n.data.cover,
  })),
];
// Рандомный порядок (разнобой) — перемешиваем на сборке
for (let i = items.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [items[i], items[j]] = [items[j], items[i]];
}

// Оптимизация Cloudinary-обложек
const cl = (u: string) =>
  u.includes('res.cloudinary.com/') ? u.replace('/upload/', '/upload/f_auto,q_auto,w_700/') : u;

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title="Моя броня — всё собрано вместе | limonesska">
    <section class="garden">
        <header class="garden-head">
            <h1 class="garden-title">Моя броня</h1>
            <p class="garden-lead">
                Всё, что я уже сковала, — статьи и заметки в одном месте. Каждая запись —
                чешуйка: какие-то крепкие и дозревшие, какие-то ещё тонкие. Всё растёт здесь.
            </p>
        </header>

        {items.length === 0 && (
            <div class="empty-state">
                <p>Скоро здесь начнёт расти броня — первые статьи и заметки</p>
            </div>
        )}

        <ul class="garden-grid">
            {items.map((it) => (
                <li>
                    <a href={it.href} class:list={["gcard", `gcard--${it.type}`]}>
                        {it.cover && (
                            <div class="gcard-img"><img src={cl(it.cover)} alt={it.title} loading="lazy" /></div>
                        )}
                        <div class="gcard-meta">
                            <span class="gcard-type">{it.typeLabel}</span>
                            {it.coming && <span class="gcard-soon">Скоро</span>}
                            {it.stage && <Icon name={`star_${it.stage}`} width={15} height={15} class="gcard-stage" />}
                            <span class="gcard-date">{fmt(it.date)}</span>
                        </div>
                        <h2 class="gcard-title">{it.title}</h2>
                        {it.description && <p class="gcard-desc">{it.description}</p>}
                    </a>
                </li>
            ))}
        </ul>
    </section>

    <style is:global>
        .garden { max-width: 1000px; margin: 0 auto; }

        .garden-head { margin-bottom: 44px; }
        .garden-title {
            font-family: var(--font-display);
            font-size: var(--size-mega);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -1px;
            color: var(--text);
            margin: 0 0 16px;
        }
        .garden-lead {
            font-family: var(--font-vollkorn);
            font-size: var(--size-medium);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0;
            max-width: 40em;
        }

        /* Колоночная раскладка — карточки разной высоты пакуются «вразнобой» */
        .empty-state {
            border: 1.5px dashed var(--line); border-radius: 16px;
            padding: 60px 28px; text-align: center; margin: 8px 0;
        }
        .empty-state p {
            font-family: var(--font-vollkorn); font-size: var(--size-medium);
            color: var(--text-muted); margin: 0 auto; max-width: 30em;
        }

        .garden-grid {
            list-style: none;
            margin: 0;
            padding: 0;
            columns: 3;
            column-gap: 18px;
        }
        .garden-grid > li {
            break-inside: avoid;
            margin-bottom: 18px;
        }

        .gcard {
            display: block;
            text-decoration: none;
            color: inherit;
            padding: 20px 22px;
            border-radius: 14px;
            border: 1px solid transparent;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
        }

        /* обложка поста */
        .gcard-img {
            margin: -20px -22px 14px;
            border-radius: 14px 14px 0 0;
            overflow: hidden;
        }
        .gcard-img img { display: block; width: 100%; height: auto; }
        /* Статьи — с обводкой и фоном; заметки — без, обводка появляется на hover */
        .gcard--post {
            border-color: var(--line);
            background: var(--card-bg);
        }
        .gcard:hover {
            border-color: var(--line);
            background: var(--card-bg);
            box-shadow: 0 12px 30px var(--shadow);
            transform: translateY(-3px);
        }

        .gcard-meta {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 10px;
            font-family: var(--font-ui);
            font-size: var(--size-small);
        }
        .gcard-type {
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--accent-2);
        }
        .gcard-date { color: var(--color-text-faint); }
        .gcard-stage { display: block; color: var(--accent-2); margin-left: 2px; position: relative; top: -1.5px; }
        .gcard-soon {
            color: var(--accent);
            font-weight: 700;
            border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
            border-radius: 999px;
            padding: 1px 8px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .gcard-title {
            font-family: var(--font-vollkorn);
            font-size: var(--size-h3);
            font-weight: 700;
            line-height: 1.3;
            color: var(--text);
            margin: 0;
            transition: color 0.2s ease;
        }
        .gcard:hover .gcard-title { color: var(--accent); }

        .gcard-desc {
            font-family: var(--font-vollkorn);
            font-size: var(--size-base);
            line-height: 1.5;
            color: var(--text-muted);
            margin: 8px 0 0;
        }

        @media (max-width: 900px) {
            .garden-grid { columns: 2; }
        }
        @media (max-width: 600px) {
            .garden-grid { columns: 1; }
        }
    </style>
</BaseLayout>
