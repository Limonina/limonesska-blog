---
import { getEntries } from '../../utils/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getEntries('blog')).sort(
  (a, b) => +b.data.pubDate - +a.data.pubDate
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });

// Рубрики и их подрубрики для фильтра (только реально встречающиеся)
const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))] as string[];
const subByCat: Record<string, string[]> = {};
for (const c of categories) {
  subByCat[c] = [
    ...new Set(
      posts.filter((p) => p.data.category === c).map((p) => p.data.subcategory).filter(Boolean)
    ),
  ] as string[];
}
const hasFilters = categories.length > 0;
---

<BaseLayout title="Блог | limonesska">
    <div class="blog-index">
        <h1 class="blog-index-title">Блог</h1>
        <p class="blog-index-subtitle">Тексты, которые пишутся дольше всего.</p>

        {hasFilters && (
            <div class="blog-filters" id="blog-filters">
                <div class="filter-row">
                    <button class="filter-chip is-active" data-cat="">Все</button>
                    {categories.map((c) => (
                        <button class="filter-chip" data-cat={c}>{c}</button>
                    ))}
                </div>
                <div class="filter-subs" id="filter-subs" hidden>
                    {categories.map((c) =>
                        subByCat[c].length > 0 ? (
                            <div class="sub-group" data-parent={c} hidden>
                                <button class="filter-chip filter-chip--sub is-active" data-sub="">все</button>
                                {subByCat[c].map((s) => (
                                    <button class="filter-chip filter-chip--sub" data-sub={s}>{s}</button>
                                ))}
                            </div>
                        ) : null
                    )}
                </div>
            </div>
        )}

        {posts.length === 0 && (
            <div class="empty-state">
                <p>Скоро здесь появятся первые статьи</p>
            </div>
        )}

        <div class="post-list" id="post-list">
            {posts.map((post) => (
                <a
                    href={`/blog/${post.id}`}
                    class="post-list-item"
                    data-category={post.data.category ?? ''}
                    data-subcategory={post.data.subcategory ?? ''}
                >
                    <div class="post-list-meta">
                        <span>{formatDate(post.data.pubDate)}</span>
                        {post.data.coming && <span class="post-soon">Скоро</span>}
                        {post.data.tags.length > 0 && (
                            <>
                                <span class="post-list-dot">•</span>
                                <span>{post.data.tags.map((t) => `#${t}`).join('  ')}</span>
                            </>
                        )}
                    </div>
                    <h2 class="post-list-heading">{post.data.title}</h2>
                    {post.data.description && (
                        <p class="post-list-desc">{post.data.description}</p>
                    )}
                </a>
            ))}
        </div>

        <p class="post-list-empty" id="post-list-empty" hidden>По этому фильтру пока ничего нет.</p>
    </div>
</BaseLayout>

<style is:global>
    .blog-index { max-width: 760px; margin: 0 auto; }
    .blog-index-title {
        font-family: var(--font-display); font-size: var(--size-mega); font-weight: 700;
        line-height: 1.1; letter-spacing: -1px; margin: 0 0 10px; color: var(--color-text);
    }
    .blog-index-subtitle {
        font-family: var(--font-vollkorn); font-size: var(--size-base);
        color: var(--color-text-soft); margin: 0 0 36px;
    }

    /* ---- Фильтры (текст через точку) ---- */
    .blog-filters { margin-bottom: 40px; }
    .filter-row { display: flex; flex-wrap: wrap; align-items: baseline; }
    .filter-chip {
        background: none; border: none; padding: 2px 0; cursor: pointer;
        font-family: var(--font-ui); font-size: var(--size-base); font-weight: 500;
        color: var(--color-text-faint); transition: color 0.2s;
    }
    .filter-chip:not(:first-child)::before {
        content: "·"; margin: 0 10px; color: var(--color-text-faint); font-weight: 400;
    }
    .filter-chip:hover { color: var(--color-text); }
    .filter-chip.is-active { color: var(--color-accent); font-weight: 700; }
    /* Подрубрики — мельче, под выбранной рубрикой */
    .filter-subs { margin-top: 12px; }
    .filter-subs[hidden] { display: none; }
    .sub-group { display: flex; flex-wrap: wrap; align-items: baseline; }
    .sub-group[hidden] { display: none; }
    .filter-chip--sub { font-size: var(--size-small); }
    .filter-chip--sub.is-active { color: var(--color-accent); }

    .post-list { display: flex; flex-direction: column; }
    .post-list-item {
        display: block; text-decoration: none; color: inherit;
        padding: 28px 0; border-top: 1px solid var(--color-border); transition: 0.2s;
    }
    .post-list-item:last-of-type { border-bottom: 1px solid var(--color-border); }
    .post-list-item[hidden] { display: none; }
    .post-list-item:hover { padding-left: 8px; }
    .post-list-item:hover .post-list-heading { color: var(--color-accent); }

    .post-list-meta {
        font-family: var(--font-ui); font-size: var(--size-small); color: var(--color-text-faint);
        text-transform: uppercase; letter-spacing: 0.5px;
        display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
    }
    .post-list-dot { color: var(--color-text-faint); }
    .post-soon {
        color: var(--color-accent); font-weight: 700; border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
        border-radius: 999px; padding: 1px 8px; letter-spacing: 1px;
    }

    .post-list-heading {
        font-family: var(--font-vollkorn); font-size: var(--size-h3); font-weight: 700;
        line-height: 1.3; margin: 0; color: var(--color-text); transition: color 0.2s;
    }
    .post-list-desc {
        font-family: var(--font-vollkorn); font-size: var(--size-base);
        color: var(--color-text-soft); line-height: 1.5; margin: 8px 0 0;
    }
    .post-list-empty {
        font-family: var(--font-vollkorn); font-size: var(--size-base);
        color: var(--color-text-muted); padding: 32px 0; text-align: center;
    }
    .empty-state {
        border: 1.5px dashed var(--color-border); border-radius: 16px;
        padding: 60px 28px; text-align: center; margin: 8px 0;
    }
    .empty-state p {
        font-family: var(--font-vollkorn); font-size: var(--size-medium);
        color: var(--color-text-muted); margin: 0;
    }

    /* Телефон: без «прыжка» вправо при тапе/наведении + мельче строка даты/тегов */
    @media (max-width: 600px) {
        .post-list-item:hover { padding-left: 0; }
        .post-list-meta { font-size: 0.66rem; gap: 4px 8px; flex-wrap: wrap; }
        .post-list-meta > span:first-child { white-space: nowrap; }
    }

</style>

<script>
    function initBlogFilters() {
        const root = document.getElementById('blog-filters');
        const list = document.getElementById('post-list');
        const empty = document.getElementById('post-list-empty');
        const subsWrap = document.getElementById('filter-subs');
        if (!root || !list) return;

        let activeCat = '';
        let activeSub = '';
        const items = Array.from(list.querySelectorAll<HTMLElement>('.post-list-item'));
        const subGroups = subsWrap ? Array.from(subsWrap.querySelectorAll<HTMLElement>('.sub-group')) : [];

        const apply = () => {
            let shown = 0;
            items.forEach((it) => {
                const okCat = !activeCat || it.dataset.category === activeCat;
                const okSub = !activeSub || it.dataset.subcategory === activeSub;
                const visible = okCat && okSub;
                it.hidden = !visible;
                if (visible) shown++;
            });
            if (empty) empty.hidden = shown !== 0;
        };

        // Показать группу подрубрик для выбранной рубрики (если есть)
        const showSubsFor = (cat: string) => {
            let anyVisible = false;
            subGroups.forEach((g) => {
                const match = !!cat && g.dataset.parent === cat;
                g.hidden = !match;
                if (match) anyVisible = true;
            });
            if (subsWrap) subsWrap.hidden = !anyVisible;
        };

        // Рубрики
        root.querySelectorAll<HTMLButtonElement>('.filter-row > .filter-chip').forEach((chip) => {
            chip.addEventListener('click', () => {
                activeCat = chip.dataset.cat || '';
                activeSub = '';
                root.querySelectorAll('.filter-row > .filter-chip').forEach((c) =>
                    c.classList.toggle('is-active', c === chip)
                );
                showSubsFor(activeCat);
                // сбросить активную подрубрику в показанной группе на «все»
                subGroups.forEach((g) =>
                    g.querySelectorAll('.filter-chip--sub').forEach((c, i) =>
                        c.classList.toggle('is-active', i === 0)
                    )
                );
                apply();
            });
        });

        // Подрубрики
        subGroups.forEach((g) => {
            g.querySelectorAll<HTMLButtonElement>('.filter-chip--sub').forEach((chip) => {
                chip.addEventListener('click', () => {
                    activeSub = chip.dataset.sub || '';
                    g.querySelectorAll('.filter-chip--sub').forEach((c) =>
                        c.classList.toggle('is-active', c === chip)
                    );
                    apply();
                });
            });
        });
    }

    if (document.readyState !== 'loading') initBlogFilters();
    else document.addEventListener('DOMContentLoaded', initBlogFilters);
</script>
