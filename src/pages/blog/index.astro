---
import { getEntries } from '../../utils/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getEntries('blog')).sort(
  (a, b) => +b.data.pubDate - +a.data.pubDate
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title="Блог | limonesska">
    <div class="blog-index">
        <h1 class="blog-index-title">Блог</h1>
        <p class="blog-index-subtitle">Тексты, которые пишутся дольше всего.</p>

        <div class="post-list">
            {posts.map((post) => (
                <a href={`/blog/${post.id}`} class="post-list-item">
                    <div class="post-list-meta">
                        <span>{formatDate(post.data.pubDate)}</span>
                        {post.data.tags.length > 0 && (
                            <>
                                <span class="post-list-dot">•</span>
                                <span>{post.data.tags.map((t) => `#${t}`).join('  ')}</span>
                            </>
                        )}
                    </div>
                    <h2 class="post-list-heading">{post.data.title}</h2>
                    {post.data.description && (
                        <p class="post-list-desc">{post.data.description}</p>
                    )}
                </a>
            ))}
        </div>
    </div>
</BaseLayout>

<style is:global>
    .blog-index { max-width: 760px; margin: 0 auto; }
    .blog-index-title {
        font-family: var(--font-display); font-size: var(--size-mega); font-weight: 700;
        line-height: 1.1; letter-spacing: -1px; margin: 0 0 10px; color: var(--color-text);
    }
    .blog-index-subtitle {
        font-family: var(--font-vollkorn); font-size: var(--size-base);
        color: var(--color-text-soft); margin: 0 0 50px;
    }

    .post-list { display: flex; flex-direction: column; }
    .post-list-item {
        display: block; text-decoration: none; color: inherit;
        padding: 28px 0; border-top: 1px solid var(--color-border); transition: 0.2s;
    }
    .post-list-item:last-child { border-bottom: 1px solid var(--color-border); }
    .post-list-item:hover { padding-left: 8px; }
    .post-list-item:hover .post-list-heading { color: var(--color-accent); }

    .post-list-meta {
        font-family: var(--font-ui); font-size: var(--size-small); color: var(--color-text-faint);
        text-transform: uppercase; letter-spacing: 0.5px;
        display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
    }
    .post-list-dot { color: var(--color-text-faint); }

    .post-list-heading {
        font-family: var(--font-vollkorn); font-size: var(--size-h3); font-weight: 700;
        line-height: 1.3; margin: 0; color: var(--color-text); transition: color 0.2s;
    }
    .post-list-desc {
        font-family: var(--font-vollkorn); font-size: var(--size-base);
        color: var(--color-text-soft); line-height: 1.5; margin: 8px 0 0;
    }
</style>
