---
import BaseLayout from '../layouts/BaseLayout.astro';

// ⤵️ Лиона редактирует. Подзаголовок под именем.
const tagline = 'Мысли · ценности · перемены';

// Фото в ряд (2 портрета). Чистые URL (Cloudinary). Пусто → плейсхолдер.
const photos = [
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621351/diary/O_1_ku20fr.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621353/diary/O_2_kq4vla.jpg',
];

// Горизонтальное фото семьи (чистый URL Cloudinary). Пусто → пунктир-плейсхолдер.
const familyPhoto = 'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621337/diary/bdb4e4b4-eadb-4fbb-bc55-31afb8129a5a_gdxtqv.jpg';

// Фото кота Изи (10 вертикальных, 5×2). Чистые URL (Cloudinary). Пусто → плейсхолдер. Порядок 1→10.
const catPhotos = [
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621338/diary/7O_1_vxydkv.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621341/diary/7O_2_horhfg.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621342/diary/7O_3_d3clo9.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621343/diary/7O_4_v0wf2v.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621344/diary/7O_5_kuyroy.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621345/diary/7O_6_s9nvo2.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621346/diary/7O_7_vothgp.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621347/diary/7O_8_qhlv9e.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621348/diary/7O_9_ju60po.jpg',
  'https://res.cloudinary.com/dikrjzavm/image/upload/v1781621339/diary/7O_10_ydlxa6.jpg',
];

// Возраст считается на сборке от даты рождения (обновляется при деплое; GitHub Actions пересобирает на пуш).
const birth = new Date('2001-12-20');
const now = new Date();
let age = now.getFullYear() - birth.getFullYear();
const hadBirthday =
    now.getMonth() > birth.getMonth() ||
    (now.getMonth() === birth.getMonth() && now.getDate() >= birth.getDate());
if (!hadBirthday) age--;
// Склонение «год / года / лет»
const yearsWord = (n: number) => {
    const a = n % 100;
    const b = n % 10;
    if (a >= 11 && a <= 14) return 'лет';
    if (b === 1) return 'год';
    if (b >= 2 && b <= 4) return 'года';
    return 'лет';
};

// Сколько лет в России — считается от переезда (1 августа 2019).
const moved = new Date('2019-08-01');
let yearsRu = now.getFullYear() - moved.getFullYear();
const hadMoveAnniv =
    now.getMonth() > moved.getMonth() ||
    (now.getMonth() === moved.getMonth() && now.getDate() >= moved.getDate());
if (!hadMoveAnniv) yearsRu--;
---

<BaseLayout title="Обо мне | limonesska">
    <article class="about">
        <header class="about-head">
            <h1 class="about-name">Обо мне</h1>
            <p class="about-tagline">{tagline}</p>
        </header>

        <!-- ── Привет ── -->
        <section class="about-section">
            <p class="about-lead about-dropcap">
                Привет! Меня зовут Лиона. Да, это моё настоящее имя, и оно правда существует.
                По крайней мере, я существую уже <span id="age">{age} {yearsWord(age)}</span>.
                Почти <span id="age-next">{age + 1}</span>… какой ужас. Это имя мне придумал папа.
                Как вы понимаете, я достаточно часто сталкиваюсь с тем, как люди удивляются, когда слышат его.
                Как-нибудь соберу список всех ассоциаций.
            </p>
            <p>
                Я родилась в Казахстане, а в Россию перебралась <span id="years-ru">{yearsRu} {yearsWord(yearsRu)}</span> назад
                и получила ВНЖ<sup class="about-fn-ref">1</sup>. Здесь же окончила университет,
                ушла с нелюбимой работы и теперь пытаюсь понять, куда всё это меня ведёт.
            </p>
            <aside class="about-sidenote"><span class="about-sidenote-num">1</span>Это были те ещё 7 кругов ада…</aside>
            <p class="about-fn"><sup>1</sup> Это были те ещё 7 кругов ада…</p>
            <div class="about-photos">
                {photos.map((src) => (
                    <div class:list={["about-photo", { "is-empty": !src }]}>
                        {src && <img src={src} alt="Лиона" loading="lazy" />}
                    </div>
                ))}
            </div>
        </section>

        <!-- ── Семья и кот ── -->
        <section class="about-section">
            <h2 class="about-h2">Семья</h2>
            <p>
                Семья у меня большая. Я первый ребёнок, а после меня появились сестрёнка
                и братишка, так что роль старшей знакома мне с самого детства. В Петербург
                я приехала первой, была, так скажем, «первооткрывателем». Родные подтянулись
                чуть позже, когда всё уже было мной разведано. Я благодарна им за своё детство
                и за все наши традиции, которые до сих пор держат нас вместе.
            </p>
            <p>
                Семья для меня — это место, где можно быть собой и ничего не доказывать.
                Место, где есть поддержка в трудную минуту, искренний интерес друг к другу и спокойное
                чувство, что рядом останутся люди, что бы ни случилось.
            </p>
            <p>
                Крепкие отношения держатся не на идеальности, а на уважении, доверии и умении
                слышать друг друга. Поэтому я берегу связь с близкими, ценю общие моменты и
                стараюсь создавать атмосферу, в которую хочется возвращаться. А ещё семья — это
                ведь не только родственные связи, но и люди, которых выбираешь сам. Те, с кем
                можно разделить радость, пережить трудное и расти вместе.
            </p>
            <blockquote class="about-pullquote">Семья — это место, где можно быть собой и ничего не доказывать.</blockquote>
            <div class:list={["about-photo", "about-photo--wide", { "is-empty": !familyPhoto }]}>
                {familyPhoto && <img src={familyPhoto} alt="Моя семья" loading="lazy" />}
            </div>
            <p>
                А ещё в моей жизни есть кот. Официально его зовут Изя, по паспорту Азраэль,
                но в быту он откликается на добрую сотню прозвищ:
            </p>
            <ul class="cat-nicks">
                <li>киса</li>
                <li>котангенс</li>
                <li>изюм</li>
                <li>кусака</li>
                <li>изолятор</li>
                <li>изька-писька</li>
                <li>изольда</li>
                <li>козёл хвостатый</li>
            </ul>
            <p>
                О кошке я мечтала с самого детства, но дома всегда отвечали: «вот съедешь,
                тогда и заведёшь». Так что свой любимый комочек я нашла только на третьем курсе
                университета. Он, кстати, отказывается есть, пока его не погладишь. Хах.
            </p>
            <div class="about-cat-photos">
                {catPhotos.map((src) => (
                    <div class:list={["about-photo", { "is-empty": !src }]}>
                        {src && <img src={src} alt="Изя" loading="lazy" />}
                    </div>
                ))}
            </div>
        </section>

        <!-- ── Люди важнее ярлыков ── -->
        <section class="about-section">
            <h2 class="about-h2">Люди важнее ярлыков</h2>
            <p>
                Меня всегда больше интересовали люди, а не ярлыки, статусы и должности.
                Я искренне верю, что самое ценное в человеке — это способность оставаться собой,
                сохранять человечность и не терять интерес к жизни, что бы ни происходило.
            </p>
            <p>
                Я умею видеть в людях больше, чем они обычно показывают окружающим. Мне интересны
                не маски и роли, а настоящие мотивы, переживания, мечты и внутренний мир.
                Возможно, именно поэтому ко мне часто приходят за советом, поддержкой или просто
                за честным разговором.
            </p>
            <p>
                Для меня важны справедливость, уважение и верность своим принципам. Я не люблю
                манипуляции, фальшь и пустые обещания. И если уж берусь за что-то, то делаю это
                осознанно и с полной отдачей.
            </p>
        </section>

        <!-- ── Рост и свобода ── -->
        <section class="about-section">
            <h2 class="about-h2">Рост и свобода</h2>
            <p>
                Я не считаю себя идеальным человеком. В моей жизни были ошибки, разочарования
                и моменты, когда приходилось начинать всё заново. Но именно они научили меня
                гибкости, терпению и умению не сдаваться после неудач. Каждый сложный этап
                делал меня сильнее и помогал лучше понимать себя и других.
            </p>
            <p>
                Меня вдохновляют люди, которые что-то создают, развиваются и не боятся идти
                своим путём. Те, кто умеет мечтать, действовать и брать ответственность за свою
                жизнь. Мне близка идея постоянного роста, но не ради чужого одобрения, а ради
                внутренней честности перед собой.
            </p>
            <p>
                Я ценю свободу. Свободу быть собой, выбирать собственный путь и менять направление,
                если чувствую, что выросла из прежнего этапа жизни. Но вместе со свободой
                всегда идут ответственность, уважение к другим людям и умение держать слово.
            </p>
        </section>

        <!-- ── Это пространство ── -->
        <section class="about-section">
            <h2 class="about-h2">Это пространство</h2>
            <p>
                Этот сайт — не попытка показать идеальную версию себя. Скорее это пространство,
                где собраны мои мысли, проекты, опыт и ценности. Всё то, что формировало меня
                на протяжении многих лет и продолжает формировать сегодня.
            </p>
        </section>

    </article>

    <div class="about-lightbox" id="about-lightbox" hidden>
        <button class="lb-close" type="button" aria-label="Закрыть">×</button>
        <button class="lb-prev" type="button" aria-label="Предыдущее фото">‹</button>
        <img class="lb-img" src="" alt="" />
        <button class="lb-next" type="button" aria-label="Следующее фото">›</button>
    </div>

    <script>
        // Возраст пересчитывается в браузере — не зависит от деплоя.
        const birth = new Date(2001, 11, 20); // 20 декабря 2001 (месяц с 0)
        const now = new Date();
        let age = now.getFullYear() - birth.getFullYear();
        const had =
            now.getMonth() > birth.getMonth() ||
            (now.getMonth() === birth.getMonth() && now.getDate() >= birth.getDate());
        if (!had) age--;
        const word = (n: number) => {
            const a = n % 100;
            const b = n % 10;
            if (a >= 11 && a <= 14) return 'лет';
            if (b === 1) return 'год';
            if (b >= 2 && b <= 4) return 'года';
            return 'лет';
        };
        const el = document.getElementById('age');
        const elNext = document.getElementById('age-next');
        if (el) el.textContent = `${age} ${word(age)}`;
        if (elNext) elNext.textContent = String(age + 1);

        // Сколько лет в России — от 1 августа 2019.
        const moved = new Date(2019, 7, 1); // 1 августа 2019 (месяц с 0)
        let yearsRu = now.getFullYear() - moved.getFullYear();
        const hadMove =
            now.getMonth() > moved.getMonth() ||
            (now.getMonth() === moved.getMonth() && now.getDate() >= moved.getDate());
        if (!hadMove) yearsRu--;
        const elRu = document.getElementById('years-ru');
        if (elRu) elRu.textContent = `${yearsRu} ${word(yearsRu)}`;

        // Сноска на правом поле: совмещаем по вертикали с маркером (только широкий экран)
        const fnRef = document.querySelector('.about-fn-ref') as HTMLElement | null;
        const sidenote = document.querySelector('.about-sidenote') as HTMLElement | null;
        if (fnRef && sidenote) {
            const place = () => {
                if (window.innerWidth < 1260) return;
                sidenote.style.top = (fnRef as HTMLElement).offsetTop + 'px';
            };
            place();
            window.addEventListener('load', place);
            if (document.fonts && document.fonts.ready) document.fonts.ready.then(place);
            let t: ReturnType<typeof setTimeout>;
            window.addEventListener('resize', () => { clearTimeout(t); t = setTimeout(place, 150); });
        }
    </script>

    <script>
        // Лайтбокс: тык по любому фото → полный экран, листание стрелками/кнопками
        const lb = document.getElementById('about-lightbox');
        if (lb) {
            const lbImg = lb.querySelector('.lb-img') as HTMLImageElement;
            const imgs = Array.from(
                document.querySelectorAll('.about-photos img, .about-photo--wide img, .about-cat-photos img')
            ) as HTMLImageElement[];
            let idx = 0;
            const show = () => {
                lbImg.src = imgs[idx].src;
                lbImg.alt = imgs[idx].alt || '';
            };
            const open = (i: number) => {
                idx = i;
                show();
                lb.hidden = false;
                document.body.style.overflow = 'hidden';
            };
            const close = () => {
                lb.hidden = true;
                document.body.style.overflow = '';
            };
            const next = () => { idx = (idx + 1) % imgs.length; show(); };
            const prev = () => { idx = (idx - 1 + imgs.length) % imgs.length; show(); };

            imgs.forEach((im, i) => {
                im.style.cursor = 'zoom-in';
                im.addEventListener('click', () => open(i));
            });
            lb.querySelector('.lb-close')!.addEventListener('click', close);
            lb.querySelector('.lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); next(); });
            lb.querySelector('.lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); prev(); });
            lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
            document.addEventListener('keydown', (e) => {
                if (lb.hidden) return;
                if (e.key === 'Escape') close();
                if (e.key === 'ArrowRight') next();
                if (e.key === 'ArrowLeft') prev();
            });
        }
    </script>

    <style is:global>
        .about { max-width: 760px; margin: 0 auto; }

        .about-head { margin-bottom: 56px; }
        .about-name {
            font-family: var(--font-display);
            font-size: var(--size-mega);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -1px;
            color: var(--text);
            margin: 0 0 10px;
        }
        .about-tagline {
            font-family: var(--font-ui);
            font-size: var(--size-small);
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--accent-2);
            margin: 0;
        }

        .about-section { margin-bottom: 56px; position: relative; }
        .about-section:last-child { margin-bottom: 0; }

        .about-h2 {
            font-family: var(--font-display);
            font-size: var(--size-h2);
            color: var(--text);
            margin: 0 0 22px;
            position: relative;
        }
        .about-h2::before {
            content: '';
            position: absolute;
            left: -38px;
            top: calc(50% + 2px); /* по центру первой заглавной буквы */
            transform: translateY(-50%);
            width: 22px;
            height: 28px;
            background-color: var(--accent-2);
            -webkit-mask: url('/icons/item.svg') no-repeat center / contain;
            mask: url('/icons/item.svg') no-repeat center / contain;
        }

        .about-section p {
            font-family: var(--font-vollkorn);
            font-size: var(--size-base);
            line-height: 1.7;
            color: var(--text-muted);
            margin: 0 0 18px;
        }
        .about-section p:last-child { margin-bottom: 0; }
        .about-section em { color: var(--color-text-faint); }
        .about-lead { font-size: var(--size-medium); color: var(--text); }

        /* буквица на первом абзаце */
        .about-dropcap::first-letter {
            float: left;
            font-family: var(--font-display);
            font-size: 3.6em;
            line-height: 0.78;
            margin: 6px 12px 0 0;
            color: var(--text);
        }

        /* клички кота — список «через точку» */
        .cat-nicks {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            padding: 0;
            margin: 0 0 18px;
            font-family: var(--font-vollkorn);
            font-style: italic;
            font-size: var(--size-base);
            color: var(--accent-2);
        }
        .cat-nicks li:not(:first-child)::before {
            content: "·";
            margin: 0 10px;
            color: var(--color-text-faint);
            font-style: normal;
        }

        /* пул-цитата */
        .about-pullquote {
            font-family: var(--font-display);
            font-size: var(--size-h2);
            line-height: 1.25;
            color: var(--text);
            margin: 10px 0;
            padding-left: 22px;
            border-left: 3px solid var(--accent-2);
        }

        /* сноска: номер инлайн, текст справа на поле (широкий экран) / снизу (узкий) */
        .about-fn-ref {
            color: var(--accent-2);
            font-weight: 700;
            font-size: 0.7em;
            vertical-align: super;
        }
        .about-sidenote {
            position: absolute;
            left: calc(100% + 32px);
            width: 210px;
            font-family: var(--font-vollkorn);
            font-size: 0.85rem;
            line-height: 1.5;
            color: var(--text-muted);
            display: none;
        }
        .about-sidenote-num {
            color: var(--accent-2);
            font-weight: 700;
            font-family: var(--font-ui);
            font-size: 0.7rem;
            vertical-align: super;
            margin-right: 4px;
        }
        .about-fn {
            font-family: var(--font-ui) !important;
            font-size: var(--size-small) !important;
            color: var(--color-text-faint) !important;
            margin-top: -8px !important;
        }
        .about-fn sup { color: var(--accent-2); font-weight: 700; margin-right: 4px; }

        /* на широком — сноска уходит на правое поле, нижний дубль прячем */
        @media (min-width: 1260px) {
            .about-sidenote { display: block; }
            .about-fn { display: none; }
        }

        /* ── Фото в ряд ── */
        .about-photos {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }
        .about-photo {
            aspect-ratio: 3 / 4;
            border-radius: 8px;
            overflow: hidden;
            background: var(--card-bg);
        }
        .about-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .about-photo.is-empty { border: 1px dashed var(--line); }

        /* горизонтальное фото семьи — на всю ширину колонки */
        .about-photo--wide {
            aspect-ratio: 3 / 2;
            margin: 24px 0;
        }

        /* фото Изи — 5 столбцов × 2 строки */
        .about-cat-photos {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
            margin-top: 22px;
        }

        /* ── Лайтбокс ── */
        .about-lightbox {
            position: fixed;
            inset: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, 0.9);
        }
        .about-lightbox[hidden] { display: none; }
        .lb-img {
            max-width: 90vw;
            max-height: 88vh;
            object-fit: contain;
            border-radius: 8px;
            box-shadow: 0 12px 48px rgba(0, 0, 0, 0.5);
        }
        .lb-close, .lb-prev, .lb-next {
            position: absolute;
            background: none;
            border: none;
            color: #fff;
            cursor: pointer;
            line-height: 1;
            padding: 12px;
            opacity: 0.75;
            transition: opacity 0.2s;
            font-family: var(--font-ui);
        }
        .lb-close:hover, .lb-prev:hover, .lb-next:hover { opacity: 1; }
        .lb-close { top: 14px; right: 20px; font-size: 2.2rem; }
        .lb-prev { left: 10px; top: 50%; transform: translateY(-50%); font-size: 3rem; }
        .lb-next { right: 10px; top: 50%; transform: translateY(-50%); font-size: 3rem; }

        @media (max-width: 700px) {
            .about-cat-photos { grid-template-columns: repeat(3, 1fr); }
        }
        @media (max-width: 460px) {
            .about-cat-photos { grid-template-columns: repeat(2, 1fr); }
        }

        /* на узких экранах поля нет — маркер заголовка встаёт инлайн, чтобы не обрезался */
        @media (max-width: 820px) {
