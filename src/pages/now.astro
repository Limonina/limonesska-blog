---
import BaseLayout from '../layouts/BaseLayout.astro';

// Когда страница последний раз актуализировалась
const updated = new Date('2026-06-16');

// ⤵️ Лиона редактирует этот массив. Каждая запись — точка на таймлайне.
//   period — подпись слева (период/«Сейчас»), title — фокус, text — описание (опц.)
//   current: true — выделить как актуальное (верхняя запись).
const timeline = [
  {
    period: 'Сейчас',
    title: 'Четвёртый месяц без работы — и запуск сайта',
    text: 'Не пауза, а разбег. Собираю «Мою броню» вживую и наконец отпускаю её в мир.',
    current: true,
  },
  {
    period: 'Май 2026',
    title: 'Замысел «Моей брони»',
    text: 'Первые идеи системы, визуальный язык чешуи и звёзд, очертания будущего сайта.',
  },
  {
    period: 'Март 2026',
    title: 'Купила домен',
    text: 'limonesska.ru и первые наброски. Маленький шаг, с которого замысел перестал быть только мыслью в голове и обрёл свой адрес в мире.',
  },
  {
    period: 'Февраль 2026',
    title: 'Решилась уйти',
    text: 'Приняла решение об увольнении. Страшно, но именно с этой точки всё и началось по-настоящему.',
  },
  {
    period: 'Январь 2024',
    title: 'Типография',
    text: 'Вторая работа — ближе к делу, к печати и материалу, но всё ещё не своё.',
  },
  {
    period: 'Август 2023',
    title: 'Официантка',
    text: 'Первая работа после диплома: подносы, смены и первая встреча с тем, как устроен взрослый труд.',
  },
  {
    period: 'Июль 2023',
    title: 'Диплом ИТМО',
    text: 'Дописала диплом — и закрыла за собой четыре петербургских года, которые сделали меня другой.',
  },
  {
    period: 'Осень 2019',
    title: 'Алматы → Петербург',
    text: 'Собрала чемодан, уехала из родного города и поступила в Университет ИТМО. Первый большой прыжок в неизвестность.',
  },
  {
    period: 'Осень 2016',
    title: 'Лицей №134',
    text: 'Старшие классы (9–11) — время, когда начала всерьёз выбирать, кем хочу быть.',
  },
  {
    period: 'Осень 2008',
    title: 'Первый класс',
    text: 'Гимназия №79 — самое начало пути, ранец, тетради и первые «надо».',
  },
  {
    period: '20 декабря 2001',
    title: 'Начало',
    text: 'Я родилась в Алматы. С этого дня и тянется вся тропа.',
  },
];

const formatDate = (date) =>
  date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title="Now — чем я живу сейчас | limonesska">
    <section class="now">
        <header class="now-head">
            <h1 class="now-title">Сейчас</h1>
            <p class="now-lead">
                Это страница <strong>Now</strong> — честный срез того, чем я живу прямо сейчас,
                и тропа из вех, что привели меня сюда. Не глянцевое резюме и не пыльный архив,
                а живой ориентир — я переписываю его каждый раз, когда меняюсь сама.
            </p>
            <p class="now-updated">Обновлено {formatDate(updated)}</p>
        </header>

        <ol class="timeline">
            {timeline.map((item) => (
                <li class:list={["tl-item", { "tl-item--current": item.current }]}>
                    <span class="tl-node" aria-hidden="true"></span>
                    <div class="tl-body">
                        <span class="tl-period">{item.period}</span>
                        <h2 class="tl-heading">{item.title}</h2>
                        {item.text && <p class="tl-text">{item.text}</p>}
                    </div>
                </li>
            ))}
        </ol>
    </section>

    <style is:global>
        .now {
            max-width: 760px;
            margin: 0 auto;
        }

        .now-head { margin-bottom: 56px; }

        .now-title {
            font-family: var(--font-display);
            font-size: var(--size-mega);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -1px;
            color: var(--text);
            margin: 0 0 20px;
        }

        .now-lead {
            font-family: var(--font-vollkorn);
            font-size: var(--size-medium);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0 0 14px;
            max-width: 36em;
        }
        .now-lead strong { color: var(--text); }

        .now-updated {
            font-family: var(--font-ui);
            font-size: var(--size-small);
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--color-text-faint);
            margin: 0;
        }

        /* ====== Таймлайн ====== */
        .timeline {
            list-style: none;
            margin: 0;
            padding: 0;
            position: relative;
        }
        /* вертикальная линия */
        .timeline::before {
            content: "";
            position: absolute;
            top: 6px;
            bottom: 6px;
            left: 7px;
            width: 2px;
            background: var(--line);
        }

        .tl-item {
            position: relative;
            padding: 0 0 40px 40px;
        }
        .tl-item:last-child { padding-bottom: 0; }

        /* узел */
        .tl-node {
            position: absolute;
            left: 0;
            top: 4px;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: var(--card-bg);
            border: 2px solid var(--accent-2);
            box-sizing: border-box;
        }
        .tl-item--current .tl-node {
            background: var(--accent-2);
            box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent-2) 22%, transparent);
        }

        .tl-period {
            display: inline-block;
            font-family: var(--font-ui);
            font-size: var(--size-small);
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--accent-2);
            margin-bottom: 6px;
        }

        .tl-heading {
            font-family: var(--font-display);
            font-size: var(--size-h3);
            color: var(--text);
            margin: 0 0 8px;
        }

        .tl-text {
            font-family: var(--font-vollkorn);
            font-size: var(--size-base);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0;
            max-width: 40em;
        }
    </style>
</BaseLayout>
