---
import BaseLayout from '../layouts/BaseLayout.astro';

// ⤵️ Лиона редактирует. Каждая запись — проект.
//   title — название, status — 'построено' | 'строится' | 'в замысле'
//   text — описание, href — ссылка (репозиторий / демо, опц.), tags — стек (опц.)
const projects = [
  {
    title: 'Лунный календарь',
    status: 'построено',
    text: 'Фазы Луны по дням, «Луна без курса», затмения и ретрограды планет — всё считается прямо в браузере, без внешних API. По клику на день — что за фаза и чего лучше не планировать. Есть печать года на A4.',
    href: '/moon',
    tags: ['astronomy-engine', 'SVG', 'печать A4'],
  },
  {
    title: 'Finance',
    status: 'строится',
    text: 'Личный финансовый учёт и аналитика.',
    href: '',
    tags: [],
  },
  {
    title: 'MyInventoryApp',
    status: 'в замысле',
    text: 'Инвентаризация вещей — что есть, где лежит, когда куплено.',
    href: '',
    tags: [],
  },
];

const statusClass = (s) =>
  s === 'построено' ? 'done' : s === 'строится' ? 'building' : 'idea';
---

<BaseLayout title="Проекты | limonesska">
    <section class="projects">
        <header class="proj-head">
            <h1 class="proj-title">Проекты</h1>
            <p class="proj-lead">
                Что-то построенное. Что-то строится. А что-то даже не знает, чем закончится.
            </p>
        </header>

        <ul class="proj-grid">
            {projects.map((p) => (
                <li class="proj-card">
                    <div class="proj-card-head">
                        <h2 class="proj-name">{p.title}</h2>
                        <span class:list={["proj-status", `st-${statusClass(p.status)}`]}>{p.status}</span>
                    </div>
                    <p class="proj-text">{p.text}</p>
                    {p.tags && p.tags.length > 0 && (
                        <div class="proj-tags">
                            {p.tags.map((t) => <span class="proj-tag">{t}</span>)}
                        </div>
                    )}
                    {p.href && (
                        <a class="proj-link" href={p.href} target="_blank" rel="noopener noreferrer">Открыть →</a>
                    )}
                </li>
            ))}
        </ul>
    </section>

    <style is:global>
        .projects { max-width: 1000px; margin: 0 auto; }

        .proj-head { margin-bottom: 48px; }
        .proj-title {
            font-family: var(--font-display);
            font-size: var(--size-mega);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -1px;
            color: var(--text);
            margin: 0 0 18px;
        }
        .proj-lead {
            font-family: var(--font-vollkorn);
            font-size: var(--size-medium);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0;
            max-width: 36em;
        }

        .proj-grid {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .proj-card {
            background: var(--card-bg);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 28px;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .proj-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px var(--shadow); }

        .proj-card-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
        }
        .proj-name {
            font-family: var(--font-vollkorn);
            font-size: var(--size-h3);
            font-weight: 600;
            color: var(--text);
            margin: 0;
        }

        .proj-status {
            flex: 0 0 auto;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: var(--font-ui);
            font-size: var(--size-small);
            font-weight: 500;
            line-height: 1;
            white-space: nowrap;
        }
        .proj-status::before {
            content: "";
            flex: 0 0 auto;
            width: 7px; height: 7px;
            border-radius: 50%;
            background: currentColor;
            position: relative;
            top: 0.5px;
        }
        .st-done { color: var(--accent-2); }
        .st-building { color: var(--accent); }
        .st-idea { color: var(--color-text-faint); }

        .proj-text {
            font-family: var(--font-vollkorn);
            font-size: var(--size-base);
            line-height: 1.6;
            color: var(--text-muted);
            margin: 0 0 16px;
        }

        .proj-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
        .proj-tag {
            font-family: var(--font-ui);
            font-size: var(--size-small);
            color: var(--color-text-soft);
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            padding: 3px 10px;
            border-radius: 20px;
        }

        .proj-link {
            margin-top: auto;
            font-family: var(--font-ui);
            font-size: var(--size-base);
            font-weight: 600;
            color: var(--accent);
            text-decoration: none;
        }
        .proj-link:hover { text-decoration: underline; }

        @media (max-width: 600px) {
            .proj-grid { grid-template-columns: 1fr; }
        }
    </style>
</BaseLayout>
