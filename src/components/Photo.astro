---
// Инлайн-фото для тела записи (дневник/посты). Использование в MDX:
//   <Photo src={frontmatter.photos[0]} />                      — по умолчанию: средний, по центру
//   <Photo src={frontmatter.photos[1]} size="l" align="wide" /> — крупное, шире текста
//   <Photo src={frontmatter.photos[2]} size="s" align="right" caption="подпись" />
// src — ссылка (обычно из массива photos: по номеру). size: s | m | l. align: center | left | right | wide.
interface Props {
  src: string;
  size?: 'xs' | 's' | 'm' | 'l';
  align?: 'center' | 'left' | 'right' | 'wide';
  caption?: string;
  alt?: string;
  crop?: string; // напр. "9:16" — обрезать вшитый пилларбокс (чёрные полосы в самом файле) по центру
  rotate?: string | number; // угол поворота в градусах (Cloudinary a_…): 90 — из вертикали в горизонталь
  clear?: 'left' | 'right' | 'both'; // сбросить обтекание предыдущим float (чтобы фото встало с нового ряда, а не сбоку)
}
const { src, size = 'm', align = 'center', caption, alt, crop, rotate, clear } = Astro.props;

// Видео Cloudinary отдаёт по пути /video/upload/ — рендерим <video> вместо <img>
const isVideo = src.includes('/video/upload/');

// Cloudinary-оптимизация (как cl() в дневнике): ширина под размер
const widths = { xs: 'w_400', s: 'w_600', m: 'w_800', l: 'w_1100' } as const;
const w = align === 'wide' ? 'w_1600' : widths[size];
// crop/rotate — отдельными сегментами впереди: обрезка по центру и/или поворот.
// После обрезки по соотношению дополнительно шейвим ~3% с краёв (w_0.94) —
// съедает тонкую чёрную полосу вшитого пилларбокса у вертикальных видео.
const cropT = (crop ? `c_crop,g_center,ar_${crop}/c_crop,g_center,w_0.94/` : '') + (rotate ? `a_${rotate}/` : '');
const opt = (u: string) =>
  u.includes('res.cloudinary.com/') ? u.replace('/upload/', `/upload/${cropT}f_auto,q_auto,${w}/`) : u;
// Видео: форсим mp4 (h264) — .mov Cloudinary отдаёт как QuickTime, не все браузеры играют
const videoSrc = (u: string) =>
  u.includes('res.cloudinary.com/')
    ? u.replace('/upload/', `/upload/${cropT}q_auto,${w}/`).replace(/\.\w+$/, '.mp4')
    : u;
// Постер видео — первый кадр (so_0) как картинка того же кадра
const poster = (u: string) =>
  u.includes('res.cloudinary.com/')
    ? u.replace('/upload/', `/upload/${cropT}so_0,f_auto,q_auto,${w}/`).replace(/\.\w+$/, '.jpg')
    : undefined;
---

<figure class:list={["dphoto", `dphoto--${size}`, `dphoto--${align}`]} style={clear ? `clear:${clear}` : undefined}>
    {isVideo ? (
        <video src={videoSrc(src)} poster={poster(src)} controls playsinline preload="metadata"></video>
    ) : (
        <img src={opt(src)} alt={alt ?? caption ?? ''} loading="lazy" />
    )}
    {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
    .dphoto { margin: 28px 0; }
    .dphoto img, .dphoto video {
        display: block;
        width: 100%;
        margin: 0;
        border-radius: 12px;
        border: 1px solid var(--line);
    }
    .dphoto figcaption {
        margin-top: 8px;
        font-family: var(--font-ui);
        font-size: var(--size-small);
        line-height: 1.4;
        color: var(--color-text-faint);
        text-align: center;
    }

    /* размеры (единая шкала xs < s < m < l) */
    .dphoto--xs { max-width: 200px; }
    .dphoto--s { max-width: 320px; }
    .dphoto--m { max-width: 460px; }
    .dphoto--l { max-width: 100%; }
    .dphoto--center { margin-left: auto; margin-right: auto; }
    /* l — всегда на всю ширину блоком, текст НЕ обтекает (даже при align=left/right) */
    .dphoto--l.dphoto--left, .dphoto--l.dphoto--right {
        float: none;
        max-width: 100%;
        margin-left: 0;
        margin-right: 0;
    }

    /* с краю — текст обтекает (ширину задаёт size s/m/l) */
    .dphoto--left, .dphoto--right { margin-top: 6px; margin-bottom: 18px; }
    .dphoto--left { float: left; margin-right: 28px; }
    .dphoto--right { float: right; margin-left: 28px; }
    .dphoto--left figcaption, .dphoto--right figcaption { text-align: left; }

    /* шире текста — выходит за колонку (только на широких экранах) */
    .dphoto--wide { max-width: none; }
    @media (min-width: 1100px) {
        .dphoto--wide {
            width: calc(100% + 200px);
            margin-left: -100px;
            margin-right: -100px;
        }
    }

    /* на узких экранах float и крупные — в одну колонку */
    @media (max-width: 600px) {
        .dphoto--left, .dphoto--right {
            float: none;
            max-width: 100%;
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>
