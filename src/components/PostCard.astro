---
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, cover, tags, pubDate, coming, verified } = post.data;

const category = tags[0] ?? 'Статья';
const formattedDate = pubDate.toLocaleDateString('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const words = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(words / 150));
---

<a href={`/blog/${post.id}`} class="latest-card">
    {cover && <img src={cover} alt={title} />}
    <div class="latest-card-content">
        <div class="card-top-row">
            {coming ? (
                <span class="post-tag post-tag--soon"><span class="card-soon-dot"></span>Скоро</span>
            ) : (
                <span class="post-tag">{category}</span>
            )}
            {verified !== undefined && (
                <span class={verified ? 'card-verified is-verified' : 'card-verified is-unverified'} title={verified ? 'Проверено лично' : 'Не проверено лично'}>
                    {verified ? (
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    ) : (
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="13"/><line x1="12" y1="16.5" x2="12" y2="16.5"/></svg>
                    )}
                    {verified ? 'Проверено' : 'Не проверено'}
                </span>
            )}
        </div>
        <h3>{title}</h3>
        {description && <p>{description}</p>}
        <div class="latest-properties-footer">
            <div class="properties-left">
                <span>{formattedDate}</span>
                <span class="dot-separator">•</span>
                <span class="read-time-block">
                    <Icon name="time" width={14} height={14} class="time-icon" /> {readingTime} мин чтения
                </span>
            </div>
            <span class="bookmark-icon-btn" title="Сохранить в закладки">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
            </span>
        </div>
    </div>
</a>

<style>
    .latest-card > img { object-position: center bottom; }
    .card-top-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }

    /* «Скоро» с мигающей точкой — как на странице-заглушке */
    .post-tag--soon { display: inline-flex; align-items: center; gap: 7px; color: var(--accent); }
    .card-soon-dot {
        width: 7px; height: 7px; border-radius: 50%; background: var(--accent);
        animation: card-soon-pulse 2s infinite;
    }
    @keyframes card-soon-pulse {
        0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 50%, transparent); }
        70% { box-shadow: 0 0 0 9px transparent; }
        100% { box-shadow: 0 0 0 0 transparent; }
    }
    .card-verified {
        display: inline-flex; align-items: center; gap: 4px; flex-shrink: 0;
        font-family: var(--font-ui); font-size: 0.65rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.5px;
        padding: 3px 8px; border-radius: 999px; border: 1px solid var(--line);
    }
    .card-verified svg { flex-shrink: 0; }
    .card-verified.is-verified { color: var(--color-accent-2); border-color: color-mix(in srgb, var(--color-accent-2) 40%, transparent); }
    .card-verified.is-unverified { color: var(--color-text-muted); }
</style>
