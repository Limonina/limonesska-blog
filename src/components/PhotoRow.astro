---
// Ряд из нескольких фото/видео в одну строчку, по центру, во всю ширину текста.
// Использование в MDX:
//   <PhotoRow srcs={[frontmatter.photos[2], frontmatter.photos[3]]} />
//   <PhotoRow srcs={[frontmatter.photos[4], frontmatter.photos[5], frontmatter.photos[6]]} />
// Ширину каждого кадра ряд делит поровну. crop/rotate — общие для всех кадров ряда.
interface Props {
  srcs: string[];
  crop?: string;  // напр. "9:16" — обрезать вшитый пилларбокс по центру
  gravity?: string; // куда «прижать» обрезку: center (по умолч.) | north (верх) | south | east | west
  rotate?: string | number;
  align?: 'center' | 'left' | 'right'; // center (по умолч.) — во всю ширину; left/right — ряд обтекается текстом сбоку
}
const { srcs, crop, gravity = 'center', rotate, align = 'center' } = Astro.props;

// после обрезки по соотношению шейвим ~3% с краёв — съедает вшитый пилларбокс (см. Photo.astro)
const cropT = (crop ? `c_crop,g_${gravity},ar_${crop}/c_crop,g_center,w_0.94/` : '') + (rotate ? `a_${rotate}/` : '');
// ширина под ряд: делим текст на N кадров → каждому ~w_600 хватает с запасом
const w = 'w_700';
const opt = (u: string) =>
  u.includes('res.cloudinary.com/') ? u.replace('/upload/', `/upload/${cropT}f_auto,q_auto,${w}/`) : u;
const isVideo = (u: string) => u.includes('/video/upload/');
const videoSrc = (u: string) =>
  u.includes('res.cloudinary.com/')
    ? u.replace('/upload/', `/upload/${cropT}q_auto,${w}/`).replace(/\.\w+$/, '.mp4')
    : u;
const poster = (u: string) =>
  u.includes('res.cloudinary.com/')
    ? u.replace('/upload/', `/upload/${cropT}so_0,f_auto,q_auto,${w}/`).replace(/\.\w+$/, '.jpg')
    : undefined;
---

<div class:list={["dphoto-row", `dphoto-row--${align}`]} style={`--n:${srcs.length}`}>
    {srcs.map((src) => (
        isVideo(src) ? (
            <video src={videoSrc(src)} poster={poster(src)} controls playsinline preload="metadata"></video>
        ) : (
            <img src={opt(src)} alt="" loading="lazy" />
        )
    ))}
</div>

<style>
    .dphoto-row {
        display: flex;
        gap: 12px;
        margin: 28px 0;
        align-items: flex-start;
    }
    .dphoto-row > img, .dphoto-row > video {
        display: block;
        flex: 1 1 0;
        min-width: 0;
        width: 100%;
        height: auto;
        margin: 0;
        border-radius: 12px;
        border: 1px solid var(--line);
    }

    /* с краю — ряд обтекается текстом сбоку (ширину держим компактной) */
    .dphoto-row--left, .dphoto-row--right {
        max-width: 360px;
        margin-top: 6px;
        margin-bottom: 18px;
    }
    .dphoto-row--left { float: left; margin-right: 28px; }
    .dphoto-row--right { float: right; margin-left: 28px; }

    /* на узких экранах float сбрасывается — ряд во всю ширину */
    @media (max-width: 600px) {
        .dphoto-row--left, .dphoto-row--right {
            float: none;
            max-width: 100%;
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>
