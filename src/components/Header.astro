---
import { Image } from 'astro:assets';
import logoLight from '../assets/limonesska_logo_white_theme.svg';
import logoDark from '../assets/limonesska_logo_dark_theme.svg';
import Icon from './Icon.astro';
---

<header class="site-header">
    <a href="/" class="logo-link">
        <Image src={logoLight} alt="limonesska logo" class="logo-img logo-light" />
        <Image src={logoDark} alt="limonesska logo" class="logo-img logo-dark" />
    </a>
    <div class="header-nav">
    <a href="/" class="home-link">Моя броня</a>
    <a href="/search" class="header-search" aria-label="Поиск" title="Поиск">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </a>
    <button class="theme-toggle" id="theme-toggle" aria-label="Переключить тему" title="Переключить тему">
        <svg class="theme-icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4.2"/>
            <path d="M12 2.5v2.2M12 19.3v2.2M4.6 4.6l1.55 1.55M17.85 17.85l1.55 1.55M2.5 12h2.2M19.3 12h2.2M4.6 19.4l1.55-1.55M17.85 6.15l1.55-1.55"/>
        </svg>
        <svg class="theme-icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.5 14.2A8.2 8.2 0 1 1 9.8 3.5a6.4 6.4 0 0 0 10.7 10.7z"/>
        </svg>
    </button>
    <div class="dropdown">
        <button class="dropbtn" id="menu-toggle" aria-label="Меню">
            <svg class="menu-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </button>
        <div class="dropdown-content">
            <div class="menu-grid">

                <a href="/diary" class="menu-item">
                    <div class="menu-icon">
                        <Icon name="Дневник" />
                    </div>
                    <div class="menu-text">
                        <span class="menu-title">Дневник</span>
                        <span class="menu-desc">Хроника в реальном времени: рутина, поездки, игры и всё, что просто происходит</span>
                    </div>
                </a>

                <a href="/projects" class="menu-item">
                    <div class="menu-icon projects-icon">
                        <div class="icon-default">
                            <Icon name="код_1" />
                        </div>
                        <div class="icon-hover">
                            <div class="icon-brackets">
                                <Icon name="код_левая" width={14} height={28} class="bracket-left" />
                                <Icon name="код_правая" width={14} height={28} class="bracket-right" />
                            </div>
                        </div>
                    </div>
                    <div class="menu-text">
                        <span class="menu-title">Проекты</span>
                        <span class="menu-desc">Что-то построенное. Что-то строится. А что-то даже не знает, чем закончится</span>
                    </div>
                </a>

                <a href="/blog" class="menu-item">
                    <div class="menu-icon">
                        <Icon name="star_max" />
                    </div>
                    <div class="menu-text">
                        <span class="menu-title">Блог</span>
                        <span class="menu-desc">Тексты, которые пишутся дольше всего. Психология, эзотерика, планы и финансы — да, всё в одном блоге</span>
                    </div>
                </a>

                <a href="/library" class="menu-item">
                    <div class="menu-icon">
                        <Icon name="Библиотека" />
                    </div>
                    <div class="menu-text">
                        <span class="menu-title">Библиотека</span>
                        <span class="menu-desc">Прочитанное с инсайтами и очередь из книг, которая меня переживёт</span>
                    </div>
                </a>

                <a href="/notes" class="menu-item">
                    <div class="menu-icon">
                        <Icon name="star_base" />
                    </div>
                    <div class="menu-text">
                        <span class="menu-title">Заметки</span>
                        <span class="menu-desc">Мой хаос того, что ещё не до конца понимаю</span>
                    </div>
                </a>

            </div>
        </div>
    </div>
    </div>
</header>

<style is:global>
    /* --- ШАПКА --- */
    .site-header {
        position: fixed; top: 14px; left: 24px; right: 24px; z-index: 100;
        display: flex; justify-content: space-between; align-items: center;
        padding: 18px 36px; background: var(--header-bg);
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        border-radius: 14px;
        box-shadow: 0 6px 28px var(--shadow);
        font-family: var(--font-ui); font-size: var(--size-base);
    }
    .logo-link { display: flex; align-items: center; text-decoration: none; }
    .logo-img { height: 40px; width: auto; display: block; }
    .logo-dark { display: none; }
    html[data-theme="dark"] .logo-light { display: none; }
    html[data-theme="dark"] .logo-dark { display: block; }

    .dropdown { position: relative; display: inline-block; }
    .header-nav { display: flex; align-items: center; gap: 20px; }

    .home-link {
        font-family: var(--font-ui); font-size: var(--size-base); font-weight: 600;
        text-decoration: none; color: var(--color-text); position: relative; padding-bottom: 2px;
        background-image: linear-gradient(var(--color-accent), var(--color-accent)), linear-gradient(var(--color-accent), var(--color-accent));
        background-position: left bottom, right bottom;
        background-size: 0% 1.5px, 0% 1.5px;
        background-repeat: no-repeat;
        transition: color 0.35s ease, background-size 0.4s ease;
    }
    .home-link:hover {
        color: var(--color-accent);
        background-size: 50% 1.5px, 50% 1.5px;
    }

    .dropbtn {
        background: none; border: none; cursor: pointer; padding: 8px;
        color: var(--color-text); transition: color 0.35s ease;
        display: flex; align-items: center; justify-content: center;
        border-radius: 8px; perspective: 400px;
    }
    .dropbtn:hover { color: var(--color-accent); }

    .theme-toggle {
        background: none; border: none; cursor: pointer; padding: 8px;
        color: var(--color-text); display: flex; align-items: center; justify-content: center;
        border-radius: 8px; transition: color 0.35s ease;
    }
    .theme-toggle:hover { color: var(--color-accent); }

    .header-search {
        display: flex; align-items: center; justify-content: center; padding: 8px;
        color: var(--color-text); border-radius: 8px; transition: color 0.35s ease;
    }
    .header-search:hover { color: var(--color-accent); }
    .theme-icon-sun { display: none; }
    .theme-icon-moon { display: block; }
    html[data-theme="dark"] .theme-icon-sun { display: block; }
    html[data-theme="dark"] .theme-icon-moon { display: none; }
    .menu-chevron { transition: transform 0.65s ease; display: block; }
    .dropbtn:hover .menu-chevron { transform: rotateY(180deg); }
    .dropdown-content {
        display: none; position: absolute; right: 0; background-color: var(--color-surface);
        width: min(560px, calc(100vw - 48px));
        box-shadow: 0px 12px 40px var(--shadow); border-radius: 16px; z-index: 10;
        border: 1px solid var(--color-border); padding: 8px;
    }
    .dropdown.is-open .dropdown-content { display: block; }

    .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
    .menu-item {
        display: flex; align-items: flex-start; gap: 14px; padding: 14px 16px;
        border-radius: 10px; text-decoration: none; color: inherit;
        transition: transform 0.4s ease, background 0.4s ease;
    }
    .menu-item:hover { background: rgba(0,0,0,0.03); transform: translateY(-1px); }
    html[data-theme="dark"] .menu-item:hover { background: rgba(255,255,255,0.05); }
    .menu-item:hover .menu-title { color: var(--color-accent); }
    .menu-icon {
        width: 32px; height: 32px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center; position: relative;
        transition: transform 0.4s ease;
        color: var(--color-accent-2); /* иконки наследуют через currentColor */
    }
    .menu-item:hover .menu-icon { transform: scale(1.08); }
    .menu-text { display: flex; flex-direction: column; }
    .menu-title {
        font-family: var(--font-ui); font-weight: 600; font-size: var(--size-base);
        color: var(--color-text); transition: color 0.4s ease; display: block; margin-bottom: 4px;
    }
    .menu-desc {
        font-family: var(--font-vollkorn); font-size: var(--size-small); color: var(--color-text-muted);
        line-height: 1.45; display: block;
    }
    .projects-icon .icon-default,
    .projects-icon .icon-hover {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        transition: opacity 0.6s ease; /* закрытие (возврат) — медленнее */
    }
    .projects-icon .icon-hover { opacity: 0; }
    .menu-item:hover .projects-icon .icon-default,
    .menu-item:hover .projects-icon .icon-hover { transition: opacity 0.4s ease; } /* открытие — быстрее */
    .menu-item:hover .projects-icon .icon-default { opacity: 0; }
    .menu-item:hover .projects-icon .icon-hover { opacity: 1; }
    .icon-brackets { display: flex; align-items: center; gap: 3px; }
    .bracket-left { transition: transform 0.6s ease; transform: translateX(8px); }
    .bracket-right { transition: transform 0.6s ease; transform: translateX(-8px); }
    .menu-item:hover .bracket-left { transform: translateX(0); transition: transform 0.4s ease; }
    .menu-item:hover .bracket-right { transform: translateX(0); transition: transform 0.4s ease; }

    @media (max-width: 560px) {
        .menu-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
        .site-header { left: 14px; right: 14px; padding: 12px 16px; }
        .header-nav { gap: 8px; }
        .home-link { display: none; }      /* дублирует логотип-домой — на телефоне прячем ради места */
        .logo-img { height: 34px; }
    }
</style>

<script>
    const menuToggle = document.getElementById('menu-toggle');
    const menuDropdown = menuToggle.closest('.dropdown');

    menuToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        menuDropdown.classList.toggle('is-open');
    });

    document.addEventListener('click', (e) => {
        if (!menuDropdown.contains(e.target)) {
            menuDropdown.classList.remove('is-open');
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') menuDropdown.classList.remove('is-open');
    });

    // ---- Переключение темы (светлая по умолчанию) ----
    const themeToggle = document.getElementById('theme-toggle');
    const root = document.documentElement;
    themeToggle.addEventListener('click', () => {
        const dark = root.getAttribute('data-theme') === 'dark';
        if (dark) {
            root.removeAttribute('data-theme');
            try { localStorage.setItem('theme', 'light'); } catch (e) {}
        } else {
            root.setAttribute('data-theme', 'dark');
            try { localStorage.setItem('theme', 'dark'); } catch (e) {}
        }
    });

    // ---- Плавный переход — включаем ПОСЛЕ первой отрисовки (чтобы не мигало на загрузке) ----
    requestAnimationFrame(() => {
        requestAnimationFrame(() => root.classList.add('theme-anim'));
    });
</script>
