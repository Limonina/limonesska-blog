---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string; // путь вида /og/<slug>.png; по умолчанию — общий сайтовый
}

const {
  title = 'limonesska | Моя броня',
  description = 'Личный блог-дневник: цифровой сад мыслей, заметок и тех-экспериментов.',
  ogImage = '/og/site.png',
} = Astro.props;

// абсолютные URL для соцсетей (Astro.site задан в astro.config)
const ogImageUrl = new URL(ogImage, Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />
    <!-- Тема до отрисовки (анти-FOUC). Светлая по умолчанию, системную не слушаем. -->
    <script is:inline>
        (function () {
            try {
                if (localStorage.getItem('theme') === 'dark') {
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
            } catch (e) {}
        })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/limonesska_logo_circle.svg" />
    <link rel="icon" href="/limonesska_logo_circle.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / соцсети -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="limonesska · Моя броня" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&family=Vollkorn:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <style is:global>
        :root {
            /* 3 СТРОГИХ ШРИФТА */
            --font-display: 'Playfair Display', Georgia, 'Times New Roman', serif;
            --font-vollkorn: 'Vollkorn', Georgia, 'Times New Roman', serif;
            --font-ui: 'Manrope', system-ui, -apple-system, 'Segoe UI', sans-serif;

            /* СТРОГАЯ ШКАЛА РАЗМЕРОВ */
            --size-mega: clamp(2.5rem, 4vw, 3.5rem);   /* h1 / hero */
            --size-h2: clamp(1.6rem, 2.5vw, 2rem);     /* заголовки секций / постов */
            --size-h3: 1.35rem;                        /* подзаголовки */
            --size-medium: 1.25rem;                    /* лид, кнопки */
            --size-base: 1rem;                         /* основной текст */
            --size-small: 0.75rem;                     /* мета, теги */

            /* ====== КАНОНИЧЕСКИЕ ТОКЕНЫ ТЕМЫ (светлая по умолчанию) ====== */
            --bg: #FAF8F5;                    /* фон страницы */
            --text: #2B2420;                  /* основной текст */
            --text-muted: #6B5F54;            /* приглушённый текст (даты, подписи) */
            --accent: #FF5C00;                /* акцент 1 (рыжий) — ссылки, действия */
            --accent-2: #2E7D6B;              /* акцент 2 (русский зелёный) — иконки, ховеры */
            --line: rgba(43,36,32,0.12);      /* линии, разделители, обводки */
            --card-bg: #FFFFFF;               /* фон карточек/блоков */
            --shadow: rgba(43,36,32,0.10);    /* цвет теней */

            /* Производные оттенки (нет в наборе из 8) — для иерархии серого/поверхностей */
            --header-bg: rgba(250,248,245,0.78);
            --footer-bg: #F1EDE8;
            --audience-bg: var(--footer-bg);   /* как у подвала (#F1EDE8) */

            /* ====== АЛИАСЫ старых имён → канонические (чтобы не править весь код) ====== */
            --color-bg: var(--bg);
            --color-surface: var(--card-bg);
            --color-text: var(--text);
            --color-text-soft: #4A4039;
            --color-text-muted: var(--text-muted);
            --color-text-faint: #8A7E72;
            --color-accent: var(--accent);
            --color-accent-2: var(--accent-2);
            --color-link: var(--accent-2); /* синий убран → внутр. ссылки/сноски зелёные */
            --color-border: var(--line);
            --color-border-soft: rgba(43,36,32,0.06);
        }

        /* ====== ТЁМНАЯ ТЕМА ====== */
        html[data-theme="dark"] {
            --bg: #14181C;
            --text: #C4BBB0;            /* мягкий приятный тон вместо резкого белого — общий для всего текста */
            --text-muted: #9A9088;
            --accent: #C74A3B;            /* красноватый акцент для тёмной */
            --accent-2: #6A9675;          /* зелёный акцент для тёмной */
            --line: rgba(234,228,220,0.14);
            --card-bg: #1C2127;
            --shadow: rgba(0,0,0,0.5);

            --header-bg: rgba(20,24,28,0.78);
            --footer-bg: #11151A;
            --audience-bg: var(--card-bg); /* в тёмной — карточный фон, как было */

            /* производные оттенки */
            --color-text-soft: #AEA59A;  /* описания/лиды чуть тише основного текста (#C4BBB0) */
            --color-text-faint: #766E66;
            --color-border-soft: rgba(234,228,220,0.07);
        }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background: var(--color-bg);
            color: var(--color-text);
            -webkit-font-smoothing: antialiased;
            font-size: 17px;
            font-variant-numeric: lining-nums;
        }
        *, *:before, *:after { box-sizing: border-box; }

        /* Плавная смена темы — класс .theme-anim вешается JS-ом ПОСЛЕ первой отрисовки,
           поэтому на загрузке перехода нет. Список кураторский (без элементов с hover-transform,
           чтобы не ломать их анимации). */
        html.theme-anim body,
        html.theme-anim .site-header,
        html.theme-anim .dropdown-content,
        html.theme-anim .site-footer,
        html.theme-anim .footer-legal,
        html.theme-anim .post-audience,
        html.theme-anim .post-backlinks,
        html.theme-anim .prose,
        html.theme-anim .prose pre {
            transition: background-color 0.25s ease, border-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
        }

        .main-content {
            max-width: 1600px; margin: 0 auto; width: 100%; padding: 150px 40px 60px;
        }

        /* На планшете/телефоне декоративные элементы (всплывашки ссылок, широкий
           код) не должны давать горизонтальный скролл. overflow-x: clip обрезает
           только по горизонтали, не делая контейнер вертикально-скроллящимся.
           Порог 1024px — ниже уровня, где показываются сноски на полях (≥1260px),
           так что их не задеваем. */
        @media (max-width: 1024px) {
            .main-content { overflow-x: clip; }
        }

        @media (max-width: 768px) {
            .main-content { padding: 110px 20px 40px; }
        }
    </style>

    <!-- GoatCounter — статистика просмотров (без кук). Замени ПОДДОМЕН на свой
         после регистрации на goatcounter.com. Не грузится в dev-сборке. -->
    {import.meta.env.PROD && (
        <script
            data-goatcounter="https://limonesska.goatcounter.com/count"
            async
            src="//gc.zgo.at/count.js"
        ></script>
    )}
</head>
<body>
    <Header />
    <main class="main-content">
        <slot />
    </main>
    <Footer />
</body>
</html>
