---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  pubDate: Date;
  tags?: string[];
  description?: string;
  readingTime?: number;
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  pubDate,
  tags = [],
  readingTime,
  backHref = '/blog',
  backLabel = 'Все статьи',
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={`${title} | limonesska`}>
    <article class="post">
        <header class="post-header">
            <a href={backHref} class="post-back">← {backLabel}</a>
            <h1 class="post-title">{title}</h1>
            <div class="post-meta">
                <span>{formattedDate}</span>
                {readingTime && (
                    <>
                        <span class="post-meta-dot">•</span>
                        <span>{readingTime} мин чтения</span>
                    </>
                )}
            </div>
            {tags.length > 0 && (
                <div class="post-tags">
                    {tags.map((tag) => <span class="post-tag-pill">#{tag}</span>)}
                </div>
            )}
        </header>

        <div class="prose">
            <slot />
        </div>
    </article>
</BaseLayout>

<style is:global>
    .post { max-width: 760px; margin: 0 auto; }

    /* --- ШАПКА ПОСТА --- */
    .post-header { border-bottom: 1px solid var(--color-border); padding-bottom: 30px; margin-bottom: 40px; }
    .post-back {
        font-family: var(--font-ui); font-size: var(--size-small); color: var(--color-text-muted);
        text-decoration: none; text-transform: uppercase; letter-spacing: 0.5px;
        display: inline-block; margin-bottom: 24px; transition: color 0.2s;
    }
    .post-back:hover { color: var(--color-accent); }
    .post-title {
        font-family: var(--font-display); font-size: var(--size-mega);
        font-weight: 700; line-height: 1.1; letter-spacing: -1px; margin: 0 0 18px; color: var(--color-text);
    }
    .post-meta {
        font-family: var(--font-ui); font-size: var(--size-small); color: var(--color-text-faint);
        text-transform: uppercase; letter-spacing: 0.5px;
        display: flex; align-items: center; gap: 8px; margin-bottom: 18px;
    }
    .post-meta-dot { color: #ccc; }
    .post-tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .post-tag-pill {
        font-family: var(--font-ui); font-size: var(--size-small);
        background: var(--color-surface); border: 1px solid var(--color-border);
        padding: 6px 14px; border-radius: 20px; color: var(--color-text-soft);
    }

    /* --- ТИПОГРАФИКА КОНТЕНТА --- */
    .prose { font-family: var(--font-vollkorn); color: var(--color-text); line-height: 1.7; }
    .prose > :first-child { margin-top: 0; }

    .prose h2 {
        font-family: var(--font-display); font-size: var(--size-h2); font-weight: 700;
        line-height: 1.2; margin: 1.8em 0 0.6em; color: var(--color-text);
    }
    .prose h3 {
        font-family: var(--font-display); font-size: var(--size-h3); font-weight: 700;
        line-height: 1.25; margin: 1.5em 0 0.5em; color: var(--color-text);
    }
    .prose p { margin: 0 0 1.4em; }

    .prose a {
        color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px;
    }
    .prose a:hover { text-decoration: none; }

    .prose blockquote {
        border-left: 3px solid var(--color-accent); margin: 1.6em 0;
        padding: 0.2em 0 0.2em 1.3em; color: var(--color-text-soft); font-style: italic;
    }

    .prose ul, .prose ol { padding-left: 1.4em; margin: 0 0 1.4em; }
    .prose li { margin-bottom: 0.5em; }

    .prose code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        background: var(--color-border-soft); padding: 0.15em 0.4em;
        border-radius: 5px; font-size: 0.9em;
    }
    .prose pre {
        background: var(--color-text); color: var(--color-bg);
        padding: 1.2em 1.4em; border-radius: 12px; overflow-x: auto; margin: 1.6em 0;
    }
    .prose pre code { background: none; padding: 0; color: inherit; }

    .prose img { max-width: 100%; height: auto; border-radius: 12px; margin: 1.6em 0; }
    .prose hr { border: none; border-top: 1px solid var(--color-border); margin: 2.5em 0; }
</style>
